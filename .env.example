# =============================================================================
# Bojemoi Lab — Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# Then source it before deploying:
#   set -a && source .env && set +a
#
# REQUIRED fields have no default (empty or marked CHANGE_ME).
# OPTIONAL fields have sensible defaults you can keep.
# =============================================================================

# -----------------------------------------------------------------------------
# NETWORK / DOMAINS
# -----------------------------------------------------------------------------

# Internal lab domain (used by Traefik labels, dns_search, hostnames)
LAB_DOMAIN=bojemoi.lab

# External public domain (used by C2 VPN server, redirectors, Lightsail)
PUBLIC_DOMAIN=bojemoi.me

# IP of the Swarm manager node (meta-76 equivalent)
MANAGER_IP=192.168.1.121

# Subnet for the outbound scan overlay network
SCAN_NET_CIDR=10.11.0.0/24

# -----------------------------------------------------------------------------
# DOCKER REGISTRY
# -----------------------------------------------------------------------------

# Local Docker registry (host:port)
IMAGE_REGISTRY=localhost:5000

# -----------------------------------------------------------------------------
# BASE PATHS
# -----------------------------------------------------------------------------

# Root directory of the bojemoi project on disk
BOJEMOI_BASE_PATH=/opt/bojemoi

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------

POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_USER=postgres

# Database names
MSF_DBNAME=msf
GRAFANA_DBNAME=grafana
IP2LOC_DBNAME=ip2location
KARACHO_DBNAME=karacho
FARADAY_DBNAME=faraday

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------

GRAFANA_ADMIN_PASSWORD=CHANGE_ME
# Used by postgres-exporter DSN
# Filled automatically from POSTGRES_PASSWORD — keep in sync if changed
PG_EXPORTER_DSN=postgresql://postgres:CHANGE_ME@postgres:5432/postgres?sslmode=disable

# Sentinel user password in grafana DB (if used)
SENTINEL_PG_PASS=CHANGE_ME

# -----------------------------------------------------------------------------
# PGADMIN
# -----------------------------------------------------------------------------

PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# FARADAY
# -----------------------------------------------------------------------------

FARADAY_USER=faraday
FARADAY_PASSWORD=CHANGE_ME
FARADAY_URL=http://faraday:5985

# Faraday workspaces (service-specific, usually keep defaults)
FARADAY_WORKSPACE_ZAP=zap
FARADAY_WORKSPACE_NUCLEI=nuclei
FARADAY_WORKSPACE_UZI=uzi

# -----------------------------------------------------------------------------
# METASPLOIT (MSF RPC)
# -----------------------------------------------------------------------------

MSF_RPC_PORT=55553
MSF_RPC_PASSWORD=CHANGE_ME
MSF_HOST=msf-teamserver

# Meterpreter listener port (Traefik TCP entrypoint + C2 target)
MSF_LPORT=4444
MSF_LPORT_BIND=24444

# -----------------------------------------------------------------------------
# C2 / REDIRECTORS
# -----------------------------------------------------------------------------

# Public IPs of Fly.io redirectors (comma-separated)
C2_REDIRECTORS=

# Relay port on the redirectors (nginx → MSF)
RELAY_PORT=8443

# VPN server hostname (bojemoi.me or your own VPS)
VPN_SERVER=${PUBLIC_DOMAIN}

# OpenVPN network
VPN_NETWORK=10.8.0.0
VPN_NETMASK=255.255.0.0

# Decoy redirect for non-C2 traffic hitting the redirector
DECOY_REDIRECT=https://www.google.com

# Allowed countries for GeoIP filter on redirectors (comma-separated ISO codes)
ALLOWED_COUNTRIES=FR,DE,BE,NL,IT,ES,GB,CH,AT,PL,SE,DK,NO,FI,PT,IE,CZ,SK,HU,RO

# Storage directory for C2 PKI (certs, keys, CCD)
C2_VPN_DIR=${BOJEMOI_BASE_PATH}/volumes/c2-vpn

# -----------------------------------------------------------------------------
# LIGHTSAIL (external VPS)
# -----------------------------------------------------------------------------

LIGHTSAIL_HOST=${PUBLIC_DOMAIN}
LIGHTSAIL_USER=ec2-user
# Path to the Lightsail SSH key on the manager node
LIGHTSAIL_KEY_PATH=/home/docker/LightsailDefaultKey-eu-central-1.pem

# -----------------------------------------------------------------------------
# FLY.IO
# -----------------------------------------------------------------------------

# Fly CLI path on the manager node
FLY_CLI_PATH=/home/docker/.fly/bin/fly

# Fly.io app name for the C2 redirector
FLY_APP=redirector-1

# Number of log lines to pull per cycle
FLY_LOG_LINES=2000
LIGHTSAIL_LOG_LINES=5000

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------

# Chat ID for pentest alerts (PTaaS group)
TELEGRAM_CHAT_ID=-5087117106

# -----------------------------------------------------------------------------
# OLLAMA / AI
# -----------------------------------------------------------------------------

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT=30

# -----------------------------------------------------------------------------
# OPTIONAL OSINT API KEYS
# (leave empty to disable the corresponding enrichment)
# -----------------------------------------------------------------------------

ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# KARACHO
# -----------------------------------------------------------------------------

KARACHO_SECRET_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# POSTFIX / MAIL
# -----------------------------------------------------------------------------

# Internal mail domain
MAIL_DOMAIN=${LAB_DOMAIN}

# -----------------------------------------------------------------------------
# SWARM NODE LABELS (informational — used in placement constraints)
# -----------------------------------------------------------------------------

# Hostname of the Swarm manager node
SWARM_MANAGER_HOSTNAME=meta-76

# Node running Suricata (socket bind-mount)
SURICATA_NODE_HOSTNAME=meta-70

# Node running logpull (needs Fly CLI + Lightsail key)
LOGPULL_NODE_HOSTNAME=meta-76

# -----------------------------------------------------------------------------
# ZAP SCANNER
# -----------------------------------------------------------------------------

TARGET_URL=https://zap.${LAB_DOMAIN}
ZAP_API_KEY=

# -----------------------------------------------------------------------------
# MASSCAN
# -----------------------------------------------------------------------------

TARGET_COUNTRY=RU
TARGET_ISP=
SCAN_PORTS=22,80,443,3389,5985,8080,8443
SCAN_RATE=10000
MAX_CIDRS=50

# -----------------------------------------------------------------------------
# TIMEZONE
# -----------------------------------------------------------------------------

TZ=Europe/Paris
