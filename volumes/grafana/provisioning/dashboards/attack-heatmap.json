      "id": 3,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
        "pieType": "donut",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": true},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRESQL_THREATINTEL}"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'ML Investigation' AS source, COUNT(*) AS count\nFROM ip_investigations\nWHERE attack_techniques IS NOT NULL\n  AND created_at >= NOW() - INTERVAL '30 days'\nUNION ALL\nSELECT 'Suricata' AS source, COUNT(*) AS count\nFROM suricata_attack_alerts\nWHERE timestamp >= NOW() - INTERVAL '30 days'",
          "refId": "A"
        }
      ],
      "title": "Source Breakdown (30d)",
      "type": "piechart"
    },
