      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRESQL_THREATINTEL}"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  attack_technique_id AS technique_id,\n  attack_technique_name AS technique_name,\n  attack_tactic AS tactic,\n  COUNT(*) AS hit_count\nFROM suricata_attack_alerts\nWHERE $__timeFilter(timestamp)\nGROUP BY 1, 2, 3\nORDER BY hit_count DESC\nLIMIT 10",
          "refId": "A"
