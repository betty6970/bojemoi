logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s] %(levelname)s %(message)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)
log = logging.getLogger('nuclei-worker')


def _read_secret(name, legacy_env=None):
    """Read sensitive value: legacy env var → NAME env var → /run/secrets/name file."""
    if legacy_env:
        v = os.getenv(legacy_env, "")
        if v:
            return v
    v = os.getenv(name.upper(), "")
    if v:
        return v
    try:
        with open(f"/run/secrets/{name}") as f:
            return f.read().strip()
    except OSError:
        return ""


# PostgreSQL
PG_HOST     = os.getenv('PG_HOST', 'postgres')
PG_PORT     = int(os.getenv('PG_PORT', '5432'))
PG_USER     = os.getenv('PG_USER', 'postgres')
PG_PASSWORD = _read_secret("postgres_password", "PG_PASSWORD")
PG_DBNAME   = os.getenv('PG_DBNAME', 'msf')

# Nuclei API
NUCLEI_API_URL = os.getenv('NUCLEI_API_URL', 'http://nuclei-api:8001')

# Redis
REDIS_HOST     = os.getenv('REDIS_HOST', 'redis')
REDIS_PORT     = int(os.getenv('REDIS_PORT', '6379'))
QUEUE_KEY      = 'pentest:nuclei_queue'
BRPOP_TIMEOUT  = 30  # secondes; None en queue item, déclenche backfill DB

# Comportement
POLL_INTERVAL   = int(os.getenv('NUCLEI_POLL_INTERVAL', '15')) # secondes entre polls de statut
SCAN_TIMEOUT    = int(os.getenv('NUCLEI_SCAN_TIMEOUT', '1200'))# timeout max par scan (20 min)
SEVERITY        = os.getenv('NUCLEI_SEVERITY', 'critical,high,medium')

# Ollama AI tag enrichment
OLLAMA_BASE_URL = os.getenv('OLLAMA_BASE_URL', 'http://ollama:11434')
OLLAMA_ENABLED  = os.getenv('OLLAMA_ENABLED', 'false').lower() == 'true'
OLLAMA_MODEL    = os.getenv('OLLAMA_MODEL', 'mistral:7b-instruct')
OLLAMA_TIMEOUT  = int(os.getenv('OLLAMA_TIMEOUT', '30'))

# Mapping produit bm12 → tags Nuclei
PRODUCT_TAG_MAP = {
