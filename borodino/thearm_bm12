def detect_vuln_indicators(services):
    """
    Analyse les banners/outputs NSE pour détecter des indicateurs de vulnérabilités.
    Retourne une liste: [{"vuln": name, "port": port, "evidence": str}, ...]
    """
    # Ports HTTP pour vérification de hint
    _HTTP_PORTS  = {80, 443, 8080, 8443, 8000, 8888, 3000, 8008, 9090, 9200, 5601}
    _FTP_PORTS   = {21, 2121}
    _HINT_PORTS  = {'redis': {6379}, 'mongodb': {27017}, 'snmp': {161}, 'nfs': {111, 2049},
                    'smb': {139, 445}, 'smtp': {25, 587, 465}}

    found = []
    seen_vulns = set()
    for port, svc_name, info, *_ in services:
        svc_lower = (svc_name or '').lower()
        info_str  = (info or '').lower()

        for vuln_name, (hint, pattern) in _VULN_INDICATORS.items():
            if vuln_name in seen_vulns:
                continue
            # Vérifier que le service/port correspond au hint
            if hint == 'http':
                if hint not in svc_lower and port not in _HTTP_PORTS:
                    continue
            elif hint == 'ftp':
                if hint not in svc_lower and port not in _FTP_PORTS:
                    continue
            elif hint in _HINT_PORTS:
                if hint not in svc_lower and port not in _HINT_PORTS[hint]:
                    continue
            else:
                if hint not in svc_lower:
                    continue

            if _re.search(pattern, info_str, _re.IGNORECASE):
                evidence = (info or '')[:120].strip()
                found.append({"vuln": vuln_name, "port": port, "evidence": evidence})
                seen_vulns.add(vuln_name)

    return found


def detect_arch_and_iot(services):
    """
    Analyse les banners (services.info) pour détecter l'arch CPU et les indicateurs IoT.
    Retourne (arch_msf | None, iot_score, iot_evidence_list).
    """
    combined = ' '.join(
        (info or '').lower()
        for _, _, info, *_ in services
        if info
    )

    # Arch : premier pattern qui matche
    arch = None
    for pattern, arch_val in _ARCH_PATTERNS:
        if _re.search(pattern, combined, _re.IGNORECASE):
            arch = arch_val
            break

    # IoT keywords
    iot_evidence = [kw for kw in _IOT_KEYWORDS if kw in combined]
    iot_score    = len(iot_evidence)

    return arch, iot_score, iot_evidence


# ─── Extraction produits depuis services.info ────────────────────────────────

_VERSION_RE = _re.compile(r'(\d+\.\d+[\d.a-z\-]*)')
_SKIP_WORDS = {'protocol', 'smtpd', 'httpd', 'daemon', 'server', 'service', 'linux', 'debian', 'ubuntu'}


def extract_products(services):
    """Parse services.info pour extraire noms de produits et versions."""
    products = []
    seen = set()
    for port, name, info, *_ in services:
        if not info or not info.strip():
            continue
        info_str = info.strip()
        m = _VERSION_RE.search(info_str)
        version = m.group(1) if m else None
        before = info_str[:m.start()].strip() if m else info_str
        words = [w for w in before.split() if w.lower() not in _SKIP_WORDS and w.isalpha()]
        product_name = words[-1] if words else (before.split()[0] if before else None)
        if not product_name or len(product_name) < 2:
            continue
        key = (product_name.lower(), port)
        if key not in seen:
            seen.add(key)
            entry = {"name": product_name, "port": port}
            if version:
                entry["version"] = version
            products.append(entry)
    return products


# ─── Construction des commandes nmap ─────────────────────────────────────────
def resolve_nse_scripts(port, service_name):
    """Résout les scripts NSE à utiliser pour un service donné."""
    svc = (service_name or "").lower().split("/")[0].strip()

    # 1. Chercher par nom de service exact
    if svc in NSE_SCRIPTS:
        return NSE_SCRIPTS[svc]

    # 2. Chercher par préfixe (ex: "http-proxy" → "http")
    for key in NSE_SCRIPTS:
        if svc.startswith(key):
            return NSE_SCRIPTS[key]

    # 3. Fallback par port connu
    if port in NSE_BY_PORT:
        category = NSE_BY_PORT[port]
        if category in NSE_SCRIPTS:
            return NSE_SCRIPTS[category]

    # 4. Fallback minimal — banner grab uniquement
    return "banner"


def build_nmap_command(host, services_list, pg_ip):
    """
    Construit UNE SEULE commande msfconsole qui scanne tous les ports d'un host.
    Au lieu de lancer N processus msfconsole (un par service).
    """
    # Détecter IPv6 et ajuster le flag nmap
    try:
        is_v6 = ipaddress.ip_address(host.split("/")[0]).version == 6
    except ValueError:
        is_v6 = False
    ipv6_part = "-6 " if is_v6 else ""

    # Collecter tous les ports et scripts
    all_ports = []
    all_scripts = set()

    for port, svc_name, *_ in services_list:
        all_ports.append(str(port))
        scripts = resolve_nse_scripts(port, svc_name)
        for s in scripts.split(","):
            all_scripts.add(s.strip())

    ports_str = ",".join(all_ports)
    scripts_str = ",".join(sorted(all_scripts))

    # Scan profond unique : version + OS + scripts ciblés
    nmap_cmd = (
        f"db_nmap -n {ipv6_part}-p {ports_str} "
        f"--script={scripts_str} "
        f"-sV -O --reason --traceroute "
        f"--spoof-mac 0 -f --mtu 16 --data-length 64 "
        f"--randomize-hosts -PA -PM -Pn "
        f"{host}"
    )

    msf_cmd = (
        f'msfconsole -q -x "'
        f"db_connect {PG_USER}:{PG_PASSWORD}@{pg_ip}/{PG_DBNAME}; "
        f"{nmap_cmd}; "
        f'quit"'
    )
    return msf_cmd


# ─── Exécution du scan ──────────────────────────────────────────────────────
def run_scan(host, host_id, pg_ip):
    services = get_host_services(host_id)
    if not services:
        print(f"[INFO] Aucun service ouvert pour {host}, skip.")
        return

    print(f"[INFO] {host} — {len(services)} services: {[(p, s) for p, s, *_ in services]}")

    # 1. Classifier le serveur
    server_type, confidence, details = classify_server(services)
    print(f"[CLASS] {host} → {server_type} (confidence: {confidence}%)")

    # 2. Construire et lancer le scan nmap unifié
    msf_cmd = build_nmap_command(host, services, pg_ip)
    print(f"[SCAN] Lancement scan profond sur {host}...")

    try:
        result = subprocess.run(
            ["/bin/sh", "-c", msf_cmd],
            timeout=SCAN_TIMEOUT,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        if result.returncode != 0:
            print(f"[WARN] msfconsole retour {result.returncode} pour {host}")
    except subprocess.TimeoutExpired:
        print(f"[TIMEOUT] Scan de {host} interrompu après {SCAN_TIMEOUT}s")
    except Exception as e:
        print(f"[ERREUR] Scan {host} : {e}")

    # 3. Re-lire les services après scan (nmap a pu en découvrir de nouveaux)
    updated_services = get_host_services(host_id)
    if updated_services and len(updated_services) != len(services):
        print(f"[INFO] Services mis à jour: {len(services)} → {len(updated_services)}")
        server_type, confidence, details = classify_server(updated_services)

    # 4. Extraire les produits depuis services.info
    final_services = updated_services if updated_services and len(updated_services) != len(services) else services
    products = extract_products(final_services)
    if products:
        details["products"] = products
        print(f"[PROD] {len(products)} produit(s): {[p['name'] + ' ' + p.get('version', '') for p in products]}")

    # 5. Détecter arch + indicateurs IoT depuis banners
    arch, iot_score, iot_evidence = detect_arch_and_iot(final_services)

    # Boost iot_embedded si banners IoT trouvés (même si score de ports insuffisant)
    if iot_score > 0:
        if server_type != 'iot_embedded':
            print(f"[IOT] Banner boost ({iot_score} indicateurs: {iot_evidence}) → iot_embedded")
            server_type = 'iot_embedded'
        details['iot_evidence'] = iot_evidence

    if arch:
        print(f"[ARCH] Arch détectée depuis banners: {arch}")
        details['arch'] = arch

    # 5b. Détecter les indicateurs de vulnérabilités (VulnHub-style)
    vuln_indicators = detect_vuln_indicators(final_services)
    if vuln_indicators:
        vuln_names = [v['vuln'] for v in vuln_indicators]
        print(f"[VULN] {len(vuln_indicators)} indicateur(s): {vuln_names}")
        details['attack_surface'] = vuln_indicators
        # Boost vuln_web si vulns web détectées (ne pas écraser iot_embedded)
        _WEB_VULNS = {'wordpress', 'joomla', 'drupal', 'shellshock', 'tomcat_manager',
                      'webdav', 'phpmyadmin', 'jenkins', 'struts', 'elasticsearch'}
        web_hits = [v for v in vuln_names if v in _WEB_VULNS]
        if web_hits and server_type not in ('iot_embedded',):
            print(f"[VULN] Boost vuln_web ({web_hits})")
            server_type = 'vuln_web'

    # Toujours stocker le type dans scan_details (utilisé par uzi)
    details['type'] = server_type

    # 6. Enrichissement OSINT
    osint_data = osint_lookup(host)

    # 7. Stocker la classification + OSINT + arch
    update_host_classification(host_id, server_type, details, osint_data, arch=arch)

    # 8. Pousser vers la queue Nuclei pour scan asynchrone
    push_to_nuclei_queue(host_id, host, details)

    threat_info = ""
    if osint_data and osint_data.get("is_malicious"):
        threat_info = f" ⚠ THREAT:{osint_data['threat_level'].upper()} score={osint_data['threat_score']}"
    print(f"[DONE] {host} — type={server_type}, services={len(updated_services or services)}{threat_info}")


# ─── Boucle principale ──────────────────────────────────────────────────────
def main():
    # Attendre PostgreSQL
    while True:
        pg_ip = get_postgres_ip()
        if not pg_ip:
            print("[ATTENTE] Résolution DNS postgres... retry dans 10s")
            time.sleep(10)
            continue
        if is_postgres_ready(pg_ip):
            print(f"[INFO] PostgreSQL détecté à {pg_ip}")
            break
        print(f"[ATTENTE] PostgreSQL pas prêt à {pg_ip}... retry dans 10s")
        time.sleep(10)

    # Charger les hôtes debug avant la boucle (mode debug uniquement)
    if MODE_DEBUG:
        debug_hosts = get_all_debug_hosts()
        if not debug_hosts:
            print("[DEBUG] Aucun hôte dans host_debug — insérer l'IP cible dans la table.")
            return
        print(f"[DEBUG] {len(debug_hosts)} hôte(s) à traiter séquentiellement.")
        debug_index = 0

    # Boucle de scan
    while True:
        if MODE_DEBUG:
            if debug_index >= len(debug_hosts):
                print("[DEBUG] Tous les hôtes debug traités — reboucle.")
                debug_hosts = get_all_debug_hosts()
                debug_index = 0
                time.sleep(60)
                continue
            _, host = debug_hosts[debug_index]
            debug_index += 1
            host_str = str(host)
            print(f"[DEBUG] Mode debug — cible {debug_index}/{len(debug_hosts)} : {host_str}")
            print(f"\n[INFO] ═══ Découverte + Scan de {host_str} (debug) ═══")
            host_id, _ = discover_all_services(host_str, pg_ip)
            if not host_id:
                print(f"[DEBUG] {host_str} injoignable — skip.")
                continue
        else:
            host_id, host = get_random_host()
            if not host:
                print("[INFO] Aucun hôte disponible, retry dans 5s...")
                time.sleep(5)
                continue
            host_str = str(host)
            print(f"\n[INFO] ═══ Scan de {host_str} (id={host_id}) ═══")

        run_scan(host_str, host_id, pg_ip)


if __name__ == "__main__":
    main()
