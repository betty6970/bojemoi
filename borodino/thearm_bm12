def update_host_classification(host_id, server_type, details, osint_data=None, arch=None):
    """Met à jour la classification du serveur et les données OSINT dans hosts."""
    conn = None
    try:
        conn = get_db_connection()
        with conn.cursor() as cur:
            confidence = details.get("confidence", 0)
            comments = f"bm12: {server_type} (confidence: {confidence}%)"

            # Enrichir scan_details avec l'OSINT
            if osint_data and not osint_data.get("skipped"):
                details["osint"] = osint_data
                threat_score = osint_data.get("threat_score", 0)
                threat_level = osint_data.get("threat_level", "clean")
                if osint_data.get("is_malicious"):
                    comments += f" | THREAT:{threat_level.upper()} score={threat_score}"

            # Champ info : flaguer les hosts malveillants pour Metasploit
            info_val = None
            if osint_data and osint_data.get("is_malicious"):
                info_val = (
                    f"THREAT:{osint_data['threat_level'].upper()} "
                    f"score={osint_data['threat_score']} "
                    f"abuse={osint_data.get('abuse_reports', 0)} "
                    f"malware={osint_data.get('malware_samples', 0)}"
                )

            if info_val:
                cur.execute(
                    """UPDATE hosts
                       SET purpose = %s,
                           comments = %s,
                           scan_details = %s,
                           info = %s,
                           last_scanned = CURRENT_DATE,
                           scan_status = 'bm12_v3'
                       WHERE id = %s;""",
                    ("server", comments, json.dumps(details), info_val, host_id),
                )
            else:
                cur.execute(
                    """UPDATE hosts
                       SET purpose = %s,
                           comments = %s,
                           scan_details = %s,
                           last_scanned = CURRENT_DATE,
                           scan_status = 'bm12_v3'
                       WHERE id = %s;""",
                    ("server", comments, json.dumps(details), host_id),
                )

            # Écrire l'arch seulement si détectée (ne pas écraser un arch valide de db_nmap)
            if arch:
                cur.execute(
                    "UPDATE hosts SET arch = %s WHERE id = %s AND (arch IS NULL OR arch = '');",
                    (arch, host_id),
                )
                print(f"[ARCH] hosts.arch = {arch} pour host {host_id}")

            conn.commit()
            print(f"[CLASS] Host {host_id} classifié: {server_type} ({confidence}%)")
    except psycopg2.Error as e:
        print(f"[ERREUR] Update classification : {e}")
    finally:
        if conn:
            conn.close()


