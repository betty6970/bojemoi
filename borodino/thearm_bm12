def discover_all_services(host, pg_ip):
    """
    Mode debug : scan nmap complet pour découvrir tous les endpoints.
    Lance db_nmap top-1000 + version detection sur la cible.
    Peuple msf.hosts et msf.services, retourne (host_id, services).
    """
    try:
        is_v6 = ipaddress.ip_address(host.split("/")[0]).version == 6
    except ValueError:
        is_v6 = False
    ipv6_part = "-6 " if is_v6 else ""

    nmap_cmd = (
        f"db_nmap -n {ipv6_part}--top-ports 1000 "
        f"-sV --version-intensity 5 -O --reason -Pn "
        f"{host}"
    )
    msf_cmd = (
        f'msfconsole -q -x "'
        f"db_connect {PG_USER}:{PG_PASSWORD}@{pg_ip}/{PG_DBNAME}; "
        f"{nmap_cmd}; "
        f'quit"'
    )

    print(f"[DEBUG] Découverte complète de tous les services sur {host}...")
    try:
        result = subprocess.run(
            ["/bin/sh", "-c", msf_cmd],
            timeout=SCAN_TIMEOUT,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        print(f"[DEBUG] Scan découverte terminé (retour: {result.returncode})")
    except subprocess.TimeoutExpired:
        print(f"[TIMEOUT] Découverte de {host} interrompue après {SCAN_TIMEOUT}s")
    except Exception as e:
        print(f"[ERREUR] Découverte {host} : {e}")

    # db_nmap crée l'entrée dans msf.hosts — récupérer le host_id
    host_id = get_host_id_by_address(host)
    if not host_id:
        print(f"[DEBUG] {host} introuvable dans msf.hosts après scan — cible peut-être hors ligne.")
        return None, []

    services = get_host_services(host_id)
    print(f"[DEBUG] {len(services)} service(s) découvert(s) sur {host}: {[(p, s) for p, s, *_ in services]}")
    return host_id, services


