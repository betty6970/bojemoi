#!/bin/ash

export HOME="/opt/bojemoi"

# Config depuis variables d'environnement (définies dans le stack)
PG_HOST="${PG_HOST:-postgres}"
PG_PORT="${PG_PORT:-5432}"
PG_USER="${PG_USER:-postgres}"
PG_PASSWORD="${PG_PASSWORD:-${POSTGRES_PASSWORD:-}}"
[ -z "$PG_PASSWORD" ] && [ -f /run/secrets/postgres_password ] && PG_PASSWORD=$(cat /run/secrets/postgres_password)
PG_DBNAME="${PG_DBNAME:-msf}"
IP2LOC_DBNAME="${IP2LOC_DBNAME:-ip2location}"
MODE_DEBUG="${MODE_DEBUG:-false}"

# Attendre que PostgreSQL soit prêt (retry indéfini)
echo "[ATTENTE] Attente PostgreSQL sur $PG_HOST:$PG_PORT..."
while true; do
    if pg_isready -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$PG_DBNAME" > /dev/null 2>&1; then
        echo "[INFO] PostgreSQL prêt sur $PG_HOST"
        break
    else
        echo "[ATTENTE] PostgreSQL pas prêt sur $PG_HOST... retry dans 10s"
    fi
    sleep 10
done

while true; do

# ── Mode DEBUG : scan direct depuis host_debug ─────────────────────────────
if [ "$MODE_DEBUG" = "true" ] || [ "$MODE_DEBUG" = "1" ]; then
    hosts=$(echo "SELECT address FROM host_debug ORDER BY id;" | \
        PGPASSWORD="$PG_PASSWORD" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$PG_DBNAME" -t | tr -d ' ')
    if [ -z "$hosts" ]; then
        echo "[DEBUG] Aucun hôte dans host_debug — retry dans 30s..."
        sleep 30
        continue
    fi
    for host in $hosts; do
        [ -z "$host" ] && continue
        echo "[DEBUG] Scan direct : $host"
        SCAN_XML="/tmp/scan_$(echo $host | tr '/' '_' | tr ':' '-').xml"
        nmap -sS -A -O --reason -Pn -oX "$SCAN_XML" "$host" 2>/dev/null || true
        python3 /usr/bin/msf_import.pyc "$SCAN_XML" || echo "[WARN] MSF import failed for $host"
        rm -f "$SCAN_XML"
        echo "[DEBUG] $host scanné."
    done
    echo "[DEBUG] Tous les hôtes debug scannés — reboucle dans 60s..."
    sleep 60
    continue
fi

# ── Mode NORMAL : sélection alternée IPv4/IPv6 (50/50) ────────────────────
if [ $(( RANDOM % 2 )) -eq 1 ]; then
    TABLE="ip2location_db1_v6"
else
    TABLE="ip2location_db1"
fi

ip=$(echo "SELECT cidr_z FROM $TABLE TABLESAMPLE SYSTEM(1) WHERE country_code = 'RU' AND nmap = '0' LIMIT 1;" | PGPASSWORD="$PG_PASSWORD" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$IP2LOC_DBNAME" -t)
output=$(echo "$ip" | tr -d '[:space:]')

# Fallback sur l'autre table si la sélection est vide
if [ -z "$output" ]; then
    if [ "$TABLE" = "ip2location_db1_v6" ]; then
        TABLE="ip2location_db1"
    else
        TABLE="ip2location_db1_v6"
    fi
    ip=$(echo "SELECT cidr_z FROM $TABLE TABLESAMPLE SYSTEM(1) WHERE country_code = 'RU' AND nmap = '0' LIMIT 1;" | PGPASSWORD="$PG_PASSWORD" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$IP2LOC_DBNAME" -t)
    output=$(echo "$ip" | tr -d '[:space:]')
fi

# Skip if CIDR is empty (TABLESAMPLE returned no rows in both tables)
if [ -z "$output" ]; then
    echo "[INFO] Aucun CIDR disponible, retry dans 10s..."
    sleep 10
    continue
fi

echo "current cidr :$output on going (table: $TABLE)"
tz=$(echo "UPDATE $TABLE SET nmap = '1', date_nmap = (SELECT CURRENT_TIMESTAMP) WHERE cidr_z >>= '$output';")
echo $tz | PGPASSWORD="$PG_PASSWORD" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$IP2LOC_DBNAME"

# Détecter IPv6 (contient ":") et ajouter le flag -6
if echo "$output" | grep -q ":"; then
    IPV6_FLAG="-6"
else
    IPV6_FLAG=""
fi

#msfconsole -q -x "db_connect $PG_USER:$PG_PASSWORD@$PG_HOST/$PG_DBNAME;db_nmap -sS -A -O --reason --traceroute --spoof-mac 0 -f  --mtu 16  --data-length 64 --randomize-hosts -PA -PM -Pn $IPV6_FLAG  $output; quit"
SCAN_XML="/tmp/scan_$(echo $output | tr '/' '_').xml"    
nmap -sS -A -O --reason --traceroute --spoof-mac 0 -f --mtu 16 --data-length 64 --randomize-hosts -PA -PM -Pn $IPV6_FLAG -oX "$SCAN_XML" "$output" 2>/dev/null || true
python3 /usr/bin/msf_import.pyc "$SCAN_XML" || echo "[WARN] MSF import failed for $output" 
rm -f "$SCAN_XML"


echo "cidr :$output done"
tz=$(echo "UPDATE $TABLE SET nmap = '2', date_nmap = (SELECT CURRENT_TIMESTAMP) WHERE cidr_z >>= '$output';")
echo $tz | PGPASSWORD="$PG_PASSWORD" psql -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" -d "$IP2LOC_DBNAME"

done

