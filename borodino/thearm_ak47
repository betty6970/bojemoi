#!/bin/ash

# Variables
set HOME="/opt/bojemoi"
export POSTGRESQL
user="postgres"            # Nom d'utilisateur PostgreSQL
password="bojemoi"             # Mot de passe PostgreSQL
dbname="msf"               # Base de données par défaut


# Attendre que PostgreSQL soit prêt (retry indéfini)
echo "[ATTENTE] Résolution DNS postgres..."
while true; do
    ip=$(ping -c 1 -W 1 "postgres" 2>/dev/null | head -n 1 | awk '{print $3}')
    sql_ip="${ip:1:-2}"
    if [ -n "$sql_ip" ] && ping -c 1 -W 1 "postgres" &>/dev/null; then
        if pg_isready -h "$sql_ip" -U "$user" -d "$dbname" > /dev/null 2>&1; then
            echo "[INFO] PostgreSQL détecté à $sql_ip"
            break
        else
            echo "[ATTENTE] PostgreSQL pas prêt à $sql_ip... retry dans 10s"
        fi
    else
        echo "[ATTENTE] Résolution DNS postgres... retry dans 10s"
    fi
    sleep 10
done

while true; do

# Sélection alternée IPv4/IPv6 (50/50)
if [ $(( RANDOM % 2 )) -eq 1 ]; then
    TABLE="ip2location_db1_v6"
else
    TABLE="ip2location_db1"
fi

ip=$(echo "SELECT cidr_z FROM $TABLE TABLESAMPLE SYSTEM(1) WHERE country_code = 'RU' AND nmap = '0' LIMIT 1;" |PGPASSWORD=bojemoi psql -h $sql_ip -U postgres -d ip2location -t )
output=$(echo "$ip" | tr -d '[:space:]')

# Fallback sur l'autre table si la sélection est vide
if [ -z "$output" ]; then
    if [ "$TABLE" = "ip2location_db1_v6" ]; then
        TABLE="ip2location_db1"
    else
        TABLE="ip2location_db1_v6"
    fi
    ip=$(echo "SELECT cidr_z FROM $TABLE TABLESAMPLE SYSTEM(1) WHERE country_code = 'RU' AND nmap = '0' LIMIT 1;" |PGPASSWORD=bojemoi psql -h $sql_ip -U postgres -d ip2location -t )
    output=$(echo "$ip" | tr -d '[:space:]')
fi

# Skip if CIDR is empty (TABLESAMPLE returned no rows in both tables)
if [ -z "$output" ]; then
    echo "[INFO] Aucun CIDR disponible, retry dans 10s..."
    sleep 10
    continue
fi

echo "current cidr :$output on going (table: $TABLE)"
tz=$(echo "UPDATE $TABLE SET nmap = '1', date_nmap = (SELECT CURRENT_TIMESTAMP) WHERE cidr_z >>= '$output';")
echo $tz |PGPASSWORD=bojemoi psql -h $sql_ip -U postgres -d ip2location

# Détecter IPv6 (contient ":") et ajouter le flag -6
if echo "$output" | grep -q ":"; then
    IPV6_FLAG="-6"
else
    IPV6_FLAG=""
fi

msfconsole -q -x "db_connect postgres:bojemoi@$sql_ip/$dbname;db_nmap -sS -A -O --reason --traceroute --spoof-mac 0 -f  --mtu 16  --data-length 64 --randomize-hosts -PA -PM -Pn $IPV6_FLAG  $output; quit"

echo "cidr :$output done"
tz=$(echo "UPDATE $TABLE SET nmap = '2', date_nmap = (SELECT CURRENT_TIMESTAMP) WHERE cidr_z >>= '$output';")
echo $tz |PGPASSWORD=bojemoi psql -h $sql_ip -U postgres -d ip2location

done

