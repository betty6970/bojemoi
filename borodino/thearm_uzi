def build_profile_filter(services):
    """
    Construit les patterns de filtrage selon le profil du serveur.
    - Ports spécifiques (SSH, SMB, distcc...) : patterns de chemin prédéfinis
    - Ports génériques (FTP, HTTP, SMTP...) : uniquement les termes produit de info
    Résultat : seuls les exploits dont fullname contient un pattern sont conservés.
    """
    allowed = set()
    for port, name, *rest in services:
        info = (rest[0] if rest else '') or ''

        # Extraire les noms de produit depuis info (avec stop-list)
        if info.strip():
            for word in re.split(r'[\s/(._\-]', info.strip().lower()):
                if len(word) >= 4 and word.isalpha() and word not in _INFO_STOP_WORDS:
                    allowed.add(word)

        # Patterns spécifiques au port (sauf ports trop génériques)
        if port in PORT_PATH_PATTERNS:
            allowed.update(PORT_PATH_PATTERNS[port])
        elif port not in PORT_TOO_GENERIC:
            svc = (name or '').lower().strip()
            if len(svc) >= 3 and svc not in ('open', 'tcp', 'udp', 'tcpwrapped'):
                allowed.add(svc)

    print(f"[PROFIL] {len(allowed)} patterns autorisés: {sorted(allowed)}")
    return allowed


