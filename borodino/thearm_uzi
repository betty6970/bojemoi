    os_paths = get_os_paths(os_name)
    print(f"[PROFIL] OS cible: '{os_name}' → chemins: {os_paths}")
    filtered = [
        mod for mod in exploits
        if any(p in mod.get('fullname', '').lower() for p in allowed_patterns)
        and any(p in mod.get('fullname', '').lower() for p in os_paths)
    ]
    print(f"[PROFIL] {len(exploits)} → {len(filtered)} exploits après filtrage profil+OS")
    return filtered


