def get_host_services_by_address(address):
    """Récupère les services ouverts pour une IP depuis msf.services."""
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "SELECT s.port, s.name FROM services s "
                    "JOIN hosts h ON h.id = s.host_id "
                    "WHERE host(h.address::inet) = %s AND s.state = 'open';",
                    (str(address),)
                )
                return cur.fetchall()
    except psycopg2.Error as e:
        print(f"[ERREUR] Récupération services {address}: {e}")
        return []


def build_targeted_exploits(client, services):
    """
    Construit une liste d'exploits ciblés basée sur les services découverts.
    Retourne une liste dédupliquée de modules exploit.
    """
    search_terms = set()
    for port, svc_name in services:
        svc = (svc_name or '').lower()
        if svc in SERVICE_EXPLOIT_MAP:
            for term in SERVICE_EXPLOIT_MAP[svc]:
                search_terms.add(term)
        elif port in PORT_SERVICE_MAP:
            mapped = PORT_SERVICE_MAP[port]
            if mapped in SERVICE_EXPLOIT_MAP:
                for term in SERVICE_EXPLOIT_MAP[mapped]:
                    search_terms.add(term)

    if not search_terms:
        print("[WARN] Aucun service mappé, fallback sur 'linux'")
        search_terms = {'linux'}

    print(f"[INFO] Termes de recherche: {sorted(search_terms)}")

    seen = set()
    exploits = []
    for term in sorted(search_terms):
        for mod in client.modules.search(term):
            name = mod.get('fullname', '')
            if name and name not in seen:
                seen.add(name)
                exploits.append(mod)

    print(f"[INFO] {len(exploits)} exploits uniques pour les services découverts")
    return exploits


# Récupérer tous les hôtes de debug depuis host_debug, ordonnés par id
def get_all_debug_hosts():
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST) as conn:
            with conn.cursor() as cur:
                cur.execute("SELECT id, address FROM host_debug ORDER BY id;")
