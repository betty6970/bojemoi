    host_id = get_host_id(address)
    if not host_id:
        print(f"[DB] Host {address} non trouvé, vuln ignorée.")
        return
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST, port=PG_PORT) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "INSERT INTO vulns (host_id, name, info, created_at, updated_at) "
                    "VALUES (%s, %s, %s, now(), now());",
                    (host_id, exploit_name, f"payload: {payload_name} | session: #{session_id}")
                )
        print(f"[DB] Vuln enregistrée: {exploit_name}")
    except Exception as e:
        print(f"[DB] Erreur report_vuln: {e}")


