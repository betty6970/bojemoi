_MSF_RANK_SEV = {
    600: 'Critical', 500: 'Critical',
    400: 'High',
    300: 'High', 200: 'Medium',
    100: 'Low',  0: 'Low',
}
_MSF_RANK_NUM = {
    600: 'S0', 500: 'S0',
    400: 'S1',
    300: 'S1', 200: 'S2',
    100: 'S3',  0: 'S3',
}

_dojo_uzi_test_id: Optional[int] = None

def _dojo_headers() -> dict:
    return {"Authorization": f"Token {DEFECTDOJO_TOKEN}"}

def _dojo_get_or_create_test() -> Optional[int]:
    global _dojo_uzi_test_id
    if _dojo_uzi_test_id:
        return _dojo_uzi_test_id
    if not DEFECTDOJO_TOKEN:
        return None
    import datetime
    base = DEFECTDOJO_URL
    h = _dojo_headers()
    try:
        # Product
        r = requests.get(f"{base}/api/v2/products/", headers=h, params={"name": DEFECTDOJO_PRODUCT}, timeout=10)
        r.raise_for_status()
        products = r.json().get("results", [])
        if products:
            product_id = products[0]["id"]
        else:
            r2 = requests.get(f"{base}/api/v2/product_types/", headers=h, params={"limit": 1}, timeout=10)
            r2.raise_for_status()
            pt = r2.json().get("results", [{}])
            prod_type_id = pt[0].get("id", 1) if pt else 1
            r3 = requests.post(f"{base}/api/v2/products/", headers=h, json={
                "name": DEFECTDOJO_PRODUCT, "description": "Metasploit exploits (uzi)",
                "prod_type": prod_type_id,
            }, timeout=10)
            r3.raise_for_status()
            product_id = r3.json()["id"]
        # Engagement
        today = str(datetime.date.today())
        r = requests.get(f"{base}/api/v2/engagements/", headers=h,
                         params={"product": product_id, "name": "uzi"}, timeout=10)
        r.raise_for_status()
        engs = r.json().get("results", [])
        if engs:
            engagement_id = engs[0]["id"]
        else:
            r2 = requests.post(f"{base}/api/v2/engagements/", headers=h, json={
                "name": "uzi", "product": product_id,
                "target_start": today, "target_end": today,
                "status": "In Progress", "engagement_type": "Interactive",
            }, timeout=10)
            r2.raise_for_status()
            engagement_id = r2.json()["id"]
        # Test type
        r = requests.get(f"{base}/api/v2/test_types/", headers=h, params={"name": "Manual"}, timeout=10)
        r.raise_for_status()
        tts = r.json().get("results", [])
        tt_id = tts[0]["id"] if tts else 1
        # Test
        r = requests.get(f"{base}/api/v2/tests/", headers=h,
                         params={"engagement": engagement_id, "title": "uzi"}, timeout=10)
        r.raise_for_status()
        tests = r.json().get("results", [])
        if tests:
            test_id = tests[0]["id"]
        else:
            r2 = requests.post(f"{base}/api/v2/tests/", headers=h, json={
                "title": "uzi", "engagement": engagement_id, "test_type": tt_id,
                "target_start": today, "target_end": today,
            }, timeout=10)
            r2.raise_for_status()
            test_id = r2.json()["id"]
        _dojo_uzi_test_id = test_id
        return test_id
    except Exception as e:
        print(f"[DOJO] setup failed: {e}")
        return None


def dojo_report_pwn(address: str, exploit_name: str, payload_name: str,
                    session_info: dict = None, mod_info: dict = None) -> bool:
    """Enregistre un exploit confirmé dans DefectDojo comme finding critique."""
    if not DEFECTDOJO_TOKEN:
        return False
    ip = str(address).split('/')[0]
    test_id = _dojo_get_or_create_test()
    if not test_id:
        return False

    rank = int((mod_info or {}).get('rank', 600))
    severity = _MSF_RANK_SEV.get(rank, 'Critical')
    num_sev = _MSF_RANK_NUM.get(rank, 'S0')

    desc_parts = [f"Exploit: {exploit_name}", f"Payload: {payload_name}"]
    if session_info:
        for k in ('platform', 'arch', 'username', 'tunnel_peer', '_sysinfo', '_getuid'):
            v = (session_info.get(k) or '').strip()
            if v:
                desc_parts.append(f"{k}: {v}")
    refs = []
    for ref_pair in (mod_info or {}).get('references', []):
        if isinstance(ref_pair, (list, tuple)) and len(ref_pair) == 2:
            ref_type, ref_val = ref_pair
            if str(ref_type).upper() == 'CVE':
                refs.append(f"CVE-{ref_val}")

    finding = {
        'title': exploit_name,
        'description': '\n'.join(desc_parts),
        'severity': severity,
        'numerical_severity': num_sev,
        'found_by': [1],
        'test': test_id,
        'active': True,
        'verified': True,
        'false_p': False,
        'risk_accepted': False,
        'endpoints': [{"host": ip}],
        'tags': ['metasploit', 'rce'],
    }
    if refs:
        finding['cve'] = refs[0]
    try:
        r = requests.post(f"{DEFECTDOJO_URL}/api/v2/findings/", headers=_dojo_headers(),
                          json=finding, timeout=10)
        if r.status_code in (200, 201):
            print(f"[DOJO] {ip} — {exploit_name} → finding {severity} créé")
            return True
        else:
            print(f"[DOJO] POST {r.status_code}: {r.text[:100]}")
            return False
    except Exception as e:
        print(f"[DOJO] POST failed: {e}")
        return False


def filter_exploits_by_profile(exploits, allowed_patterns, os_name=''):
