def extract_search_terms_via_ai(services):
    """Utilise Claude uniquement pour les services dont le produit n'est pas couvert par le mapping statique."""
    if not _anthropic_sdk:
        return set()
    api_key = os.getenv("ANTHROPIC_API_KEY") or read_secret("anthropic_api_key")
    if not api_key:
        return set()

    # Termes déjà couverts par le mapping statique
    covered_terms = set()
    for port, svc_name, *_ in services:
        svc = (svc_name or '').lower()
        if svc in SERVICE_EXPLOIT_MAP:
            covered_terms.update(t.lower() for t in SERVICE_EXPLOIT_MAP[svc])
        elif port in PORT_SERVICE_MAP:
            mapped = PORT_SERVICE_MAP[port]
            if mapped in SERVICE_EXPLOIT_MAP:
                covered_terms.update(t.lower() for t in SERVICE_EXPLOIT_MAP[mapped])

    # Ne garder que les services dont le 1er mot de info n'est pas déjà couvert
    unmapped = []
    for port, name, info in services:
        if not info or not info.strip():
            continue
        first_word = re.split(r'[\s/(]', info.strip().lower())[0]
        if not first_word or len(first_word) < 3:
            continue
        already = any(first_word.startswith(t) or t.startswith(first_word) for t in covered_terms)
        if not already:
            unmapped.append({"port": port, "name": name or "", "info": info})

    if not unmapped:
        print("[AI] Tous les services couverts par le mapping statique — skip")
        return set()

    print(f"[AI] {len(unmapped)} service(s) non couvert(s) → appel Claude Haiku")
    try:
        client = _anthropic_sdk.Anthropic(api_key=api_key)
        response = client.messages.create(
            model="claude-haiku-4-5",
            max_tokens=256,
            messages=[{
                "role": "user",
                "content": (
                    "Extract Metasploit module search terms from these network services.\n"
                    "Return only product/software names that match MSF exploit module names.\n"
                    f"Services:\n{json.dumps(unmapped, indent=2)}\n"
                    'Return JSON: {"search_terms": ["term1", "term2", ...]}\n'
                    "Examples: vsftpd, proftpd, distcc, bind, postfix"
                )
            }],
            output_config={"format": {
                "type": "json_schema",
                "schema": {
                    "type": "object",
                    "properties": {
                        "search_terms": {"type": "array", "items": {"type": "string"}}
                    },
                    "required": ["search_terms"],
                    "additionalProperties": False
                }
            }}
        )
        data = json.loads(response.content[0].text)
        terms = set(t.lower() for t in data.get("search_terms", []))
        print(f"[AI] Termes extraits: {sorted(terms)}")
        return terms
    except Exception as e:
        print(f"[AI] Extraction échouée: {e}")
        return set()


def build_targeted_exploits(client, services, os_name='', products=None, scan_details=None):
    """
    Construit une liste d'exploits ciblés basée sur les services découverts.
    Si products (depuis bm12_v3 scan_details) est fourni, utilisé en priorité.
    attack_surface (depuis bm12 detect_vuln_indicators) enrichit les termes de recherche.
    Retourne une liste dédupliquée de modules exploit.
    """
    search_terms = set()

    # Priorité : produits identifiés par bm12_v3
    if products:
        for p in products:
            name = (p.get('name') or '').lower().strip()
            if name and len(name) >= 3:
                search_terms.add(name)
        print(f"[PROD] Termes depuis bm12_v3 products: {sorted(search_terms)}")

    # Termes depuis attack_surface bm12 (VulnHub indicators)
    attack_surface = (scan_details or {}).get('attack_surface', [])
    if attack_surface:
        as_terms = set()
        for indicator in attack_surface:
            vuln_name = indicator.get('vuln', '')
            for term in _VULN_EXPLOIT_TERMS.get(vuln_name, []):
                as_terms.add(term)
        if as_terms:
            print(f"[VULN] Termes depuis attack_surface: {sorted(as_terms)}")
            search_terms.update(as_terms)

    # Fallback : mapping statique service → termes si aucun produit
    if not search_terms:
        for port, svc_name, *_ in services:
            svc = (svc_name or '').lower()
            if svc in SERVICE_EXPLOIT_MAP:
                for term in SERVICE_EXPLOIT_MAP[svc]:
                    search_terms.add(term)
            elif port in PORT_SERVICE_MAP:
                mapped = PORT_SERVICE_MAP[port]
                if mapped in SERVICE_EXPLOIT_MAP:
                    for term in SERVICE_EXPLOIT_MAP[mapped]:
                        search_terms.add(term)

        # Enrichissement IA uniquement si pas de produits bm12
        ai_terms = extract_search_terms_via_ai(services)
        search_terms.update(ai_terms)

    if not search_terms:
        print("[WARN] Aucun service mappé, fallback sur 'linux'")
        search_terms = {'linux'}

    print(f"[INFO] Termes de recherche: {sorted(search_terms)}")

    seen = set()
    exploits = []
    for term in sorted(search_terms):
        for mod in client.modules.search(term):
            name = mod.get('fullname', '')
            if name and name not in seen:
                seen.add(name)
                exploits.append(mod)

    # Filtrage par profil serveur + OS de la cible
    profile_patterns = build_profile_filter(services)
    exploits = filter_exploits_by_profile(exploits, profile_patterns, os_name)

    print(f"[INFO] {len(exploits)} exploits uniques pour les services découverts")
    return exploits


