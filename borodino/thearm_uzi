def _detect_local_ip() -> str:
    for url in ("https://api.ipify.org", "https://ifconfig.me/ip", "https://icanhazip.com"):
        try:
            resp = requests.get(url, timeout=5)
            ip = resp.text.strip()
            if ip:
                print(f"[INFO] IP publique détectée via {url}: {ip}")
                return ip
        except Exception:
            continue
    # Fallback : IP locale
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        print(f"[WARN] IP publique non disponible, fallback IP locale: {ip}")
        return ip
    except Exception:
        return ""

def _pick_redirector() -> str:
    """Pick a random redirector IP from C2_REDIRECTORS (comma-separated).
    Falls back to LHOST env, then auto-detect."""
    redirectors_env = os.getenv("C2_REDIRECTORS", "")
    if redirectors_env:
        candidates = [ip.strip() for ip in redirectors_env.split(",") if ip.strip()]
        if candidates:
            import random
            chosen = random.choice(candidates)
            print(f"[INFO] Redirecteur sélectionné: {chosen} (pool: {candidates})")
            return chosen
    return os.getenv("LHOST", "") or _detect_local_ip()

