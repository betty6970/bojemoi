def read_secret(name: str) -> str | None:
    # Env var takes priority (allows override without recreating Docker secrets)
    env_val = os.getenv(name.upper())
    if env_val:
        return env_val
    p = Path(f"/run/secrets/{name}")
    if p.exists():
        return p.read_text().strip()
    return None


def send_telegram_alert(sessions: dict, host: str) -> None:
    token = read_secret("telegram_bot_token")
    chat_id = read_secret("telegram_alert_chat_id")
    if not token or not chat_id:
        print("[WARN] Secrets Telegram non disponibles, alerte ignorée.")
        return

    lines = [f"💥 <b>UZI — Session ouverte sur {html.escape(host)}</b>"]
    for sid, info in sessions.items():
        via = html.escape(info.get("via_exploit", "?"))
        payload = html.escape(info.get("via_payload", "?"))
        stype = html.escape(info.get("type", "?"))
        user = html.escape(info.get("username", "?"))
        platform = html.escape(info.get("platform", "?"))
        arch = html.escape(info.get("arch", "?"))
        tunnel = html.escape(info.get("tunnel_peer", ""))
        line = (
            f"\n🔑 Session #{sid}\n"
            f"  Type     : {stype}\n"
            f"  Exploit  : {via}\n"
            f"  Payload  : {payload}\n"
            f"  Platform : {platform}/{arch}\n"
            f"  User     : {user}"
        )
        if tunnel:
            line += f"\n  Tunnel   : {tunnel}"
        sysinfo = (info.get("_sysinfo") or "").split('\n')[0][:80]
        getuid  = (info.get("_getuid") or "").strip()
        getpid  = (info.get("_getpid") or "").strip()
        if sysinfo:
            line += f"\n  Sysinfo  : {html.escape(sysinfo)}"
        if getuid:
            line += f"\n  UID      : {html.escape(getuid)}"
        if getpid:
            line += f"\n  PID      : {html.escape(getpid)}"
        lines.append(line)

    text = "\n".join(lines)
    try:
        resp = requests.post(
            f"https://api.telegram.org/bot{token}/sendMessage",
            json={"chat_id": int(chat_id), "text": text, "parse_mode": "HTML",
                  "disable_web_page_preview": True},
            timeout=15,
        )
        if resp.status_code == 200:
            print(f"[INFO] Alerte Telegram envoyée ({len(sessions)} session(s)).")
        else:
            print(f"[WARN] Telegram API {resp.status_code}: {resp.text}")
    except Exception as e:
        print(f"[ERREUR] Envoi Telegram échoué : {e}")

# Récupérer l'adresse IP du serveur PostgreSQL
def get_postgres_ip():
    try:
        return socket.gethostbyname(PG_HOST)
    except socket.gaierror:
        print(f"[ERREUR] Impossible de résoudre {PG_HOST}")
        return None

# Vérifier si PostgreSQL est prêt
def is_postgres_ready(ip):
    try:
        result = subprocess.run(
            ["pg_isready", "-h", ip, "-U", PG_USER, "-d", PG_DBNAME],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        return result.returncode == 0
    except Exception as e:
        print(f"[ERREUR] Vérification PostgreSQL échouée : {e}")
        return False

