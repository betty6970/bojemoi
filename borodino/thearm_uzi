def _detect_local_ip() -> str:
    for url in ("https://api.ipify.org", "https://ifconfig.me/ip", "https://icanhazip.com"):
        try:
            resp = requests.get(url, timeout=5)
            ip = resp.text.strip()
            if ip:
                print(f"[INFO] IP publique détectée via {url}: {ip}")
                return ip
        except Exception:
            continue
    # Fallback : IP locale
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        print(f"[WARN] IP publique non disponible, fallback IP locale: {ip}")
        return ip
    except Exception:
        return ""

LHOST = os.getenv("LHOST", "") or _detect_local_ip()
