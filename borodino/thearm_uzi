def get_os_paths(os_name):
    """Retourne les préfixes de chemin d'exploit autorisés selon l'OS de la cible."""
    os_lower = (os_name or '').lower()
    # IoT/embedded en premier (avant linux générique)
    if any(k in os_lower for k in ('iot', 'embedded', 'openwrt', 'busybox',
                                    'ddwrt', 'tomato', 'uclibc', 'router')):
        return _OS_EXPLOIT_PATHS['iot']
    # Web app vulnérables (WordPress, Joomla, Drupal, Shellshock...)
    if 'vuln_web' in os_lower or 'webapp' in os_lower:
        return _OS_EXPLOIT_PATHS['vuln_web']
    if 'windows' in os_lower:
        return _OS_EXPLOIT_PATHS['windows']
    if 'linux' in os_lower or 'ubuntu' in os_lower or 'debian' in os_lower:
        return _OS_EXPLOIT_PATHS['linux']
    if 'mac' in os_lower or 'osx' in os_lower or 'darwin' in os_lower:
        return _OS_EXPLOIT_PATHS['osx']
    if 'bsd' in os_lower:
        return _OS_EXPLOIT_PATHS['bsd']
    if 'solaris' in os_lower or 'sunos' in os_lower:
        return _OS_EXPLOIT_PATHS['solaris']
    if 'android' in os_lower:
        return _OS_EXPLOIT_PATHS['android']
    return ['exploit/multi/']  # OS inconnu → multi seulement


def get_host_os(address):
    """Récupère l'OS de la cible depuis msf.hosts."""
    try:
        with psycopg2.connect(dbname=PG_DBNAME, user=PG_USER, password=PG_PASSWORD, host=PG_HOST, port=PG_PORT) as conn:
            with conn.cursor() as cur:
                cur.execute(
                    "SELECT os_name FROM hosts WHERE host(address::inet) = %s LIMIT 1;",
                    (str(address),)
                )
                row = cur.fetchone()
                return row[0] if row else None
    except Exception:
        return None


